@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Faculty TimeGrid</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=DM+Sans:wght@500;700&family=JetBrains+Mono&family=Manrope:wght@600;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "secondary-fixed-dim": "#bbc6e9",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-container": "#e4ffe7",
                        "on-primary-container": "#f7f7ff",
                        "outline-variant": "#c2c6d6",
                        "secondary-container": "#cfd9fd",
                        "inverse-on-surface": "#eff1f6",
                        "on-background": "#181c20",
                        "tertiary-container": "#008349",
                        "inverse-surface": "#2d3135",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed-variant": "#3b4663",
                        "error-container": "#ffdad6",
                        "tertiary-fixed-dim": "#5cde90",
                        "surface-variant": "#e0e2e7",
                        "on-surface-variant": "#424653",
                        "surface": "#f7f9fe",
                        "inverse-primary": "#b0c6ff",
                        "surface-container-low": "#f1f4f9",
                        "surface-container-high": "#e6e8ed",
                        "error": "#ba1a1a",
                        "on-secondary": "#ffffff",
                        "on-primary-fixed-variant": "#00429c",
                        "on-tertiary": "#ffffff",
                        "outline": "#737785",
                        "secondary-fixed": "#dae2ff",
                        "surface-tint": "#0358cb",
                        "on-primary-fixed": "#001945",
                        "primary-fixed-dim": "#b0c6ff",
                        "on-tertiary-fixed-variant": "#00522c",
                        "primary-container": "#2d6cdf",
                        "on-secondary-fixed": "#0f1b35",
                        "surface-container-highest": "#e0e2e7",
                        "surface-container": "#eceef3",
                        "on-primary": "#ffffff",
                        "on-error": "#ffffff",
                        "surface-dim": "#d8dadf",
                        "secondary": "#535e7c",
                        "on-surface": "#181c20",
                        "tertiary": "#006738",
                        "primary-fixed": "#d9e2ff",
                        "background": "#f7f9fe",
                        "surface-bright": "#f7f9fe",
                        "on-secondary-container": "#545e7d",
                        "tertiary-fixed": "#7afbaa",
                        "primary": "#0053c1",
                        "on-tertiary-fixed": "#00210e"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"],
                        "mono": ["JetBrains Mono"],
                        "brand": ["DM Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="text-on-surface selection:bg-primary-container selection:text-on-primary-container">

<!-- SIDEBAR -->
<aside class="fixed left-0 top-0 h-full w-[220px] bg-[#1a2540] flex flex-col shadow-xl z-50">
    <div class="p-6">
        <h1 class="font-brand font-bold text-xl text-white">Academic Curator</h1>
        <p class="text-[10px] text-slate-400 uppercase tracking-widest mt-1">Admin Console</p>
    </div>
    <nav class="flex-1 px-2 space-y-1">
        @{
            string NavClass(string segment) =>
                Context.Request.Path.StartsWithSegments(segment)
                    ? "flex items-center gap-3 bg-[#2d6cdf]/10 text-white border-l-4 border-[#2d6cdf] px-4 py-3 transition-all duration-200 font-medium text-sm"
                    : "flex items-center gap-3 text-slate-400 hover:text-slate-200 px-4 py-3 hover:bg-white/5 transition-colors font-medium text-sm";
        }

        <a asp-page="/Admin/Dashboard" class="@NavClass("/Admin/Dashboard")">
            <span class="material-symbols-outlined">dashboard</span> Overview
        </a>

        <p class="px-4 pt-4 pb-1 text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Master Data</p>

        <a asp-page="/Admin/Departments/Index" class="@NavClass("/Admin/Departments")">
            <span class="material-symbols-outlined">corporate_fare</span> Departments
        </a>
        <a asp-page="/Admin/AcademicYears/Index" class="@NavClass("/Admin/AcademicYears")">
            <span class="material-symbols-outlined">event_note</span> Academic Years
        </a>
        <a asp-page="/Admin/Rooms/Index" class="@NavClass("/Admin/Rooms")">
            <span class="material-symbols-outlined">meeting_room</span> Rooms
        </a>
        <a asp-page="/Admin/Teachers/Index" class="@NavClass("/Admin/Teachers")">
            <span class="material-symbols-outlined">person</span> Teachers
        </a>
        <a asp-page="/Admin/Subjects/Index" class="@NavClass("/Admin/Subjects")">
            <span class="material-symbols-outlined">menu_book</span> Subjects
        </a>
        <a asp-page="/Admin/Classes/Index" class="@NavClass("/Admin/Classes")">
            <span class="material-symbols-outlined">groups</span> Classes
        </a>

        <p class="px-4 pt-4 pb-1 text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Timetable</p>

        <a asp-page="/Admin/Timetable/AutoGenerate" class="@NavClass("/Admin/Timetable/AutoGenerate")">
            <span class="material-symbols-outlined">auto_mode</span> Auto-Generate
        </a>
        <a asp-page="/Admin/Timetable/Create" class="@NavClass("/Admin/Timetable/Create")">
            <span class="material-symbols-outlined">add_circle</span> Create Slot
        </a>
        <a asp-page="/Admin/Timetable/ByClass" class="@NavClass("/Admin/Timetable/ByClass")">
            <span class="material-symbols-outlined">grid_view</span> View by Class
        </a>
        <a asp-page="/Admin/Timetable/ByTeacher" class="@NavClass("/Admin/Timetable/ByTeacher")">
            <span class="material-symbols-outlined">person_search</span> View by Teacher
        </a>
        <a asp-page="/Admin/Timetable/Conflicts" class="@NavClass("/Admin/Timetable/Conflicts")">
            <span class="material-symbols-outlined">warning</span> Conflicts
        </a>

        <p class="px-4 pt-4 pb-1 text-[10px] text-slate-500 uppercase tracking-widest font-semibold">Substitutions</p>

        <a asp-page="/Admin/Substitutions/Index" class="@NavClass("/Admin/Substitutions")">
            <span class="material-symbols-outlined">swap_horiz</span> Manage
        </a>
    </nav>
    <div class="p-4 mt-auto border-t border-white/10">
        <!-- Placeholder for future user menu -->
    </div>
</aside>

<!-- MAIN CONTENT -->
<main class="ml-[220px] min-h-screen">

    <!-- TOP BAR -->
    <header class="fixed top-0 right-0 w-[calc(100%-220px)] h-16 bg-[#f7f9fe] flex justify-between items-center px-8 z-40">
        <div class="flex items-center gap-4">
            <h2 class="font-brand font-semibold text-lg text-primary">@ViewData["Title"]</h2>
            @if (ViewData["Section"] != null)
            {
                <span class="px-2 py-0.5 rounded-md bg-secondary-container text-on-secondary-container text-xs font-bold uppercase tracking-tight">@ViewData["Section"]</span>
            }
        </div>
        <div class="flex items-center gap-6">
            <div class="flex items-center gap-3">
                <button class="text-slate-500 hover:text-primary transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </div>
            <div class="h-8 w-[1px] bg-outline-variant/30"></div>
            <div class="flex items-center gap-3">
                <span class="text-sm font-semibold text-on-surface mono-text">
                    @(ViewData["ActiveSemester"]?.ToString() ?? "No Active Semester")
                </span>
                @await RenderSectionAsync("TopBarAction", required: false)
            </div>
        </div>
    </header>

    <!-- FLASH MESSAGES -->
    <div class="fixed top-16 right-0 w-[calc(100%-220px)] z-30 px-8 pt-3">
        @if (TempData["Success"] != null)
        {
            <div class="flash-alert flex items-center gap-3 bg-[#dcfce7] border-l-4 border-[#22c55e] rounded-xl px-6 py-3 mb-2 shadow-sm">
                <span class="material-symbols-outlined text-[#22c55e]" style="font-variation-settings:'FILL' 1;">check_circle</span>
                <span class="text-sm font-medium text-[#006738]">@TempData["Success"]</span>
                <button onclick="this.parentElement.remove()" class="ml-auto text-[#006738] opacity-60 hover:opacity-100">
                    <span class="material-symbols-outlined text-sm">close</span>
                </button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="flash-alert flex items-center gap-3 bg-error-container/30 border-l-4 border-error rounded-xl px-6 py-3 mb-2 shadow-sm">
                <span class="material-symbols-outlined text-error" style="font-variation-settings:'FILL' 1;">error</span>
                <span class="text-sm font-medium text-error">@TempData["Error"]</span>
                <button onclick="this.parentElement.remove()" class="ml-auto text-error opacity-60 hover:opacity-100">
                    <span class="material-symbols-outlined text-sm">close</span>
                </button>
            </div>
        }
    </div>

    <!-- PAGE BODY -->
    <div class="pt-24 px-8 pb-16 max-w-7xl mx-auto space-y-6">
        @RenderBody()
    </div>

    <!-- STATUS BAR -->
    <footer class="fixed bottom-0 right-0 w-[calc(100%-220px)] h-10 bg-surface-container-low flex items-center px-8 gap-6 z-40 border-t border-outline-variant/10">
        <span class="text-xs text-slate-500 mono-text">@(ViewData["StatusBar"] ?? "Faculty TimeGrid · Admin Console")</span>
    </footer>
</main>

<!-- SHARED DELETE MODAL -->
<div id="deleteModal" class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-on-surface/40 backdrop-blur-sm hidden">
    <div class="bg-surface-container-lowest w-full max-w-md rounded-2xl shadow-2xl p-8 border border-outline-variant/20">
        <div class="w-16 h-16 bg-error-container/30 text-error rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-3xl" style="font-variation-settings:'FILL' 1;">warning</span>
        </div>
        <h4 class="text-xl font-bold text-on-surface text-center mb-2">Delete <span id="deleteModalEntityName"></span>?</h4>
        <p class="text-slate-500 text-center mb-8 leading-relaxed">This action cannot be undone.</p>
        <div class="grid grid-cols-2 gap-4">
            <button onclick="hideDeleteModal()" class="px-6 py-3 bg-surface-container-low text-on-surface font-bold rounded-xl hover:bg-surface-container-high transition-colors">Keep it</button>
            <button id="deleteModalConfirm" class="px-6 py-3 bg-error text-white font-bold rounded-xl shadow-lg shadow-error/20 hover:bg-error/90 transition-all">Yes, Delete</button>
        </div>
    </div>
</div>

<!-- FLOATING HELP BUTTON -->
<button class="fixed bottom-8 right-8 w-14 h-14 bg-primary-container text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-50">
    <span class="material-symbols-outlined">support_agent</span>
</button>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>