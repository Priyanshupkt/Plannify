@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — Faculty TimeGrid</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=DM+Sans:wght@500;700&family=JetBrains+Mono&family=Manrope:wght@600;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "secondary-fixed-dim": "#bbc6e9",
                        "surface-container-lowest": "#ffffff",
                        "on-tertiary-container": "#e4ffe7",
                        "on-primary-container": "#f7f7ff",
                        "outline-variant": "#c2c6d6",
                        "secondary-container": "#cfd9fd",
                        "inverse-on-surface": "#eff1f6",
                        "on-background": "#181c20",
                        "tertiary-container": "#008349",
                        "inverse-surface": "#2d3135",
                        "on-error-container": "#93000a",
                        "on-secondary-fixed-variant": "#3b4663",
                        "error-container": "#ffdad6",
                        "tertiary-fixed-dim": "#5cde90",
                        "surface-variant": "#e0e2e7",
                        "on-surface-variant": "#424653",
                        "surface": "#f7f9fe",
                        "inverse-primary": "#b0c6ff",
                        "surface-container-low": "#f1f4f9",
                        "surface-container-high": "#e6e8ed",
                        "error": "#ba1a1a",
                        "on-secondary": "#ffffff",
                        "on-primary-fixed-variant": "#00429c",
                        "on-tertiary": "#ffffff",
                        "outline": "#737785",
                        "secondary-fixed": "#dae2ff",
                        "surface-tint": "#0358cb",
                        "on-primary-fixed": "#001945",
                        "primary-fixed-dim": "#b0c6ff",
                        "on-tertiary-fixed-variant": "#00522c",
                        "primary-container": "#2d6cdf",
                        "on-secondary-fixed": "#0f1b35",
                        "surface-container-highest": "#e0e2e7",
                        "surface-container": "#eceef3",
                        "on-primary": "#ffffff",
                        "on-error": "#ffffff",
                        "surface-dim": "#d8dadf",
                        "secondary": "#535e7c",
                        "on-surface": "#181c20",
                        "tertiary": "#006738",
                        "primary-fixed": "#d9e2ff",
                        "background": "#f7f9fe",
                        "surface-bright": "#f7f9fe",
                        "on-secondary-container": "#545e7d",
                        "tertiary-fixed": "#7afbaa",
                        "primary": "#0053c1",
                        "on-tertiary-fixed": "#00210e"
                    },
                    fontFamily: {
                        "headline": ["Manrope"],
                        "body": ["Inter"],
                        "label": ["Inter"],
                        "mono": ["JetBrains Mono"],
                        "brand": ["DM Sans"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="bg-[#f7f9fe] min-h-screen flex items-center justify-center">
    @RenderBody()
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
