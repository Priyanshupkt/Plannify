@{
    ViewData["Layout"] = "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Faculty TimeGrid Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>
</head>
<body>
    <div class="d-flex">
        <!-- SIDEBAR -->
        <nav class="sidebar bg-dark text-white">
            <!-- Logo -->
            <div class="sidebar-header">
                <h5 class="mb-0">
                    <i class="fas fa-graduation-cap"></i> TimeGrid Pro
                </h5>
            </div>

            <!-- User Info -->
            <div class="user-info">
                <small>Logged in as:</small>
                <div class="font-weight-bold">@User.Identity?.Name</div>
                <span class="badge bg-info">@(User.FindFirst("Role")?.Value ?? "User")</span>
            </div>

            <!-- Navigation Sections -->
            <div class="sidebar-menu">
                <!-- Dashboard -->
                <div class="menu-section">
                    <p class="menu-title">📊 Dashboard</p>
                    <a href="/Admin/Dashboard" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fas fa-chart-line"></i> Dashboard
                    </a>
                </div>

                <!-- Master Data -->
                <div class="menu-section">
                    <p class="menu-title">🏗️ Master Data</p>
                    <a href="/Admin/Departments" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Departments" ? "active" : "")">
                        <i class="fas fa-building"></i> Departments
                    </a>
                    <a href="/Admin/AcademicYears" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "AcademicYears" ? "active" : "")">
                        <i class="fas fa-calendar"></i> Academic Years
                    </a>
                    <a href="/Admin/Rooms" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Rooms" ? "active" : "")">
                        <i class="fas fa-door-open"></i> Rooms
                    </a>
                    <a href="/Admin/Teachers" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Teachers" ? "active" : "")">
                        <i class="fas fa-chalkboard-user"></i> Teachers
                    </a>
                    <a href="/Admin/Subjects" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Subjects" ? "active" : "")">
                        <i class="fas fa-book"></i> Subjects
                    </a>
                    <a href="/Admin/Classes" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Classes" ? "active" : "")">
                        <i class="fas fa-users"></i> Classes & Batches
                    </a>
                </div>

                <!-- Timetable -->
                <div class="menu-section">
                    <p class="menu-title">📅 Timetable</p>
                    <a href="/Admin/Timetable" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Timetable" ? "active" : "")">
                        <i class="fas fa-clock"></i> Create Timetable
                    </a>
                    <a href="/Admin/Timetable/ByClass" class="menu-item">
                        <i class="fas fa-th"></i> View by Class
                    </a>
                    <a href="/Admin/Timetable/ByTeacher" class="menu-item">
                        <i class="fas fa-user-tie"></i> View by Teacher
                    </a>
                    <a href="/Admin/Timetable/ByRoom" class="menu-item">
                        <i class="fas fa-map-location-dot"></i> View by Room
                    </a>
                    <a href="/Admin/Timetable/Conflicts" class="menu-item">
                        <i class="fas fa-exclamation-triangle"></i> Conflict Report
                    </a>
                </div>

                <!-- Substitutions -->
                <div class="menu-section">
                    <p class="menu-title">👥 Substitutions</p>
                    <a href="/Admin/Substitutions" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Substitutions" ? "active" : "")">
                        <i class="fas fa-exchange"></i> Manage Substitutions
                    </a>
                </div>

                <!-- User Management -->
                <div class="menu-section">
                    <p class="menu-title">👤 User Management</p>
                    <a href="/Admin/Users" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "Users" ? "active" : "")">
                        <i class="fas fa-users-cog"></i> Manage Users
                    </a>
                </div>

                <!-- System -->
                <div class="menu-section">
                    <p class="menu-title">⚙️ System</p>
                    <a href="/Admin/AuditLogs" class="menu-item @(ViewData["ActiveNav"]?.ToString() == "AuditLogs" ? "active" : "")">
                        <i class="fas fa-history"></i> Audit Logs
                    </a>
                    <a href="/Auth/ChangePassword" class="menu-item">
                        <i class="fas fa-key"></i> Change Password
                    </a>
                    <form method="post" action="/Auth/Logout" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="menu-item btn-logout">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <main class="main-content flex-grow-1">
            <!-- Top Bar -->
            <div class="topbar">
                <div class="topbar-left">
                    <span class="breadcrumb-text">@ViewData["PageTitle"]</span>
                </div>
                <div class="topbar-right">
                    <select class="form-select semester-selector" style="max-width: 200px;">
                        <option>Current Semester</option>
                    </select>
                </div>
            </div>

            <!-- Flash Messages -->
            <div class="container-fluid mt-3">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            <!-- Page Content -->
            <div class="container-fluid page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
