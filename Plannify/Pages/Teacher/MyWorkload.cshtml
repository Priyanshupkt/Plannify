@page
@model Plannify.Pages.Teacher.MyWorkloadModel
@{
    ViewData["Title"] = "My Workload";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Weekly Workload Summary</h2>

    @if (Model.ActiveSemester != null)
    {
        <!-- Summary Cards Row -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Teaching Hours</h6>
                        <h3 class="card-text text-primary">@Model.WeeklyTeachingHours / @Model.MaxWeeklyHours</h3>
                        <small class="text-muted">hours per week</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Theory Hours</h6>
                        <h3 class="card-text text-info">@Model.TheoryHours</h3>
                        <small class="text-muted">hours</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Lab Hours</h6>
                        <h3 class="card-text text-success">@Model.LabHours</h3>
                        <small class="text-muted">hours</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title text-muted">Busiest Day</h6>
                        <h3 class="card-text text-warning">@Model.BusiestDay.Substring(0, 3)</h3>
                        <small class="text-muted">peak day</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Workload Progress Bar -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title">Weekly Workload Progress</h6>
                        @{
                            double percentage = Model.MaxWeeklyHours > 0 ? (double)Model.WeeklyTeachingHours / Model.MaxWeeklyHours * 100 : 0;
                            string progressClass = percentage <= 75 ? "bg-success" : percentage <= 90 ? "bg-warning" : "bg-danger";
                        }
                        <div class="progress" role="progressbar" style="height: 25px;">
                            <div class="progress-bar @progressClass" style="width: @Math.Min(percentage, 100)%">
                                @Math.Round(percentage, 1)%
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Day Breakdown Table -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Daily Breakdown</h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Day</th>
                                        <th class="text-center">Teaching Hours</th>
                                        <th class="text-center">GAP Hours</th>
                                        <th class="text-center">Subjects</th>
                                        <th class="text-center">Classes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var day in Model.DayBreakdown)
                                    {
                                        <tr>
                                            <td><strong>@day.Day</strong></td>
                                            <td class="text-center">@day.TeachingHours hrs</td>
                                            <td class="text-center">@day.GapHours hrs</td>
                                            <td class="text-center">@day.Subjects</td>
                                            <td class="text-center">@day.Classes</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Subject Distribution -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Subject Distribution</h6>
                    </div>
                    <div class="card-body">
                        @if (Model.SubjectBreakdown.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Subject</th>
                                            <th>Classes</th>
                                            <th class="text-center">Sessions/Week</th>
                                            <th class="text-center">Total Hours</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subject in Model.SubjectBreakdown)
                                        {
                                            <tr>
                                                <td><strong>@subject.SubjectName</strong></td>
                                                <td>@subject.Classes</td>
                                                <td class="text-center">@subject.SessionsPerWeek</td>
                                                <td class="text-center">@subject.TotalHours hrs</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No subject assignments found.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No active semester found. Please contact administration.
        </div>
    }
</div>
