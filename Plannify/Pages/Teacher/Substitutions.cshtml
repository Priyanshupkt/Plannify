@page
@model Plannify.Pages.Teacher.SubstitutionsModel
@{
    ViewData["Title"] = "My Substitution History";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Substitution History</h2>

    <!-- Slots I Covered -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Slots I Covered</h6>
                </div>
                <div class="card-body">
                    @if (Model.SlotsICovered.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>For Teacher</th>
                                        <th>Time</th>
                                        <th>Subject</th>
                                        <th>Class</th>
                                        <th>Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in Model.SlotsICovered)
                                    {
                                        <tr>
                                            <td>@sub.Date</td>
                                            <td>@sub.OriginalTeacher?.FullName</td>
                                            <td>@sub.TimetableSlot?.StartTime:HH:mm – @sub.TimetableSlot?.EndTime:HH:mm</td>
                                            <td>@sub.TimetableSlot?.Subject?.Name</td>
                                            <td>@sub.TimetableSlot?.ClassBatch?.BatchName</td>
                                            <td>@sub.Reason</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No records found.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Slots Covered for Me -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Slots Covered for Me</h6>
                </div>
                <div class="card-body">
                    @if (Model.SlotsCoveredForMe.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Covered By</th>
                                        <th>Time</th>
                                        <th>Subject</th>
                                        <th>Class</th>
                                        <th>Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in Model.SlotsCoveredForMe)
                                    {
                                        <tr>
                                            <td>@sub.Date</td>
                                            <td>@sub.SubstituteTeacher?.FullName</td>
                                            <td>@sub.TimetableSlot?.StartTime:HH:mm – @sub.TimetableSlot?.EndTime:HH:mm</td>
                                            <td>@sub.TimetableSlot?.Subject?.Name</td>
                                            <td>@sub.TimetableSlot?.ClassBatch?.BatchName</td>
                                            <td>@sub.Reason</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No records found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
