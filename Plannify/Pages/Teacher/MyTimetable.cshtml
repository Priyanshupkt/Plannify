@page
@model Plannify.Pages.Teacher.MyTimetableModel
@{
    ViewData["Title"] = "My Timetable";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">My Timetable</h2>

    <div class="row mb-4">
        <div class="col-md-4">
            <label for="semesterSelect" class="form-label">Select Semester</label>
            <select class="form-select" id="semesterSelect" onchange="changeSemester()" asp-items="Model.Semesters">
                <option value="">-- Select Semester --</option>
            </select>
        </div>
        <div class="col-md-8 d-flex justify-content-end align-items-end">
            <button onclick="window.print()" class="btn btn-primary">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>

    @if (Model.CurrentTeacher != null && Model.CurrentSemester != null && Model.TimeRanges.Count > 0)
    {
        <div class="card">
            <div class="card-body p-0" style="overflow-x: auto;">
                <table class="table table-bordered table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="min-width: 100px;">Time</th>
                            @foreach (var day in Model.Days)
                            {
                                <th class="text-center" style="min-width: 120px;">@day.Substring(0, 3)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var timeRange in Model.TimeRanges)
                        {
                            <tr>
                                <td class="text-center text-nowrap fw-bold">
                                    <small>@timeRange</small>
                                </td>
                                @foreach (var day in Model.Days)
                                {
                                    var slot = Model.Grid[day][timeRange];
                                    string bgClass = "bg-light";
                                    
                                    if (slot != null)
                                    {
                                        bgClass = slot.SlotType switch
                                        {
                                            "Theory" => "bg-white",
                                            "Lab" => "tg-lab",
                                            "GAP" => "tg-gap",
                                            "Elective" => "bg-light-purple",
                                            _ => "bg-light"
                                        };
                                    }

                                    <td class="@bgClass text-center align-middle" style="min-height: 60px;">
                                        @if (slot != null)
                                        {
                                            <div class="small">
                                                <strong>@slot.Subject?.Name</strong><br>
                                                <span class="text-muted">@slot.ClassBatch?.BatchName</span><br>
                                                <span class="text-muted">@slot.Room?.RoomNumber</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Free</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else if (Model.CurrentTeacher != null && Model.CurrentSemester != null)
    {
        <div class="alert alert-info">
            No slots scheduled for this semester.
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Select a semester to view your timetable.
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeSemester() {
            const semesterId = document.getElementById('semesterSelect').value;
            if (semesterId) {
                window.location = `?semesterId=${semesterId}`;
            }
        }
    </script>
}
