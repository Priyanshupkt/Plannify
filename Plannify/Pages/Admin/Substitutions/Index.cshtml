@page
@model Plannify.Pages.Admin.Substitutions.IndexModel
@{
    ViewData["Title"] = "Manage Substitutions";
}

<div class="container-fluid mt-4">
    <h2 class="mb-4">Record Substitution</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Substitution Form -->
    <div class="row mb-5">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <form method="post" asp-page-handler="Assign">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="date" class="form-label">Date</label>
                            <input type="date" class="form-control" id="date" asp-for="Input.Date" required onchange="loadAbsentTeacherSlots()">
                        </div>

                        <div class="mb-3">
                            <label for="absentTeacherId" class="form-label">Absent Teacher</label>
                            <select class="form-select" id="absentTeacherId" asp-for="Input.AbsentTeacherId" asp-items="Model.Teachers" required onchange="loadAbsentTeacherSlots()">
                                <option value="">-- Select Teacher --</option>
                            </select>
                        </div>

                        <div class="mb-3" id="slotsContainer" style="display: none;">
                            <label class="form-label">Select Slot</label>
                            <div id="slotsList"></div>
                        </div>

                        <div class="mb-3" style="display: none;" id="substitutesContainer">
                            <label for="substituteTeacherId" class="form-label">Available Substitutes</label>
                            <select class="form-select" id="substituteTeacherId" asp-for="Input.SubstituteTeacherId" required>
                                <option value="">-- Select Substitute --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="reason" class="form-label">Reason</label>
                            <textarea class="form-control" id="reason" asp-for="Input.Reason" rows="3" placeholder="e.g., Medical leave, Conference attendance"></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="approvedBy" class="form-label">Approved By</label>
                            <input type="text" class="form-control" id="approvedBy" asp-for="Input.ApprovedBy" value="@User.Identity?.Name" readonly>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100" id="submitBtn" disabled>
                            Assign Substitute
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- History Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Substitution History</h6>
                </div>
                <div class="card-body">
                    @if (Model.SubstitutionHistory.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Absent Teacher</th>
                                        <th>Slot</th>
                                        <th>Subject</th>
                                        <th>Class</th>
                                        <th>Substitute</th>
                                        <th>Reason</th>
                                        <th>Recorded By</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var sub in Model.SubstitutionHistory)
                                    {
                                        <tr>
                                            <td>@sub.Date:d</td>
                                            <td><strong>@sub.OriginalTeacher?.FullName</strong></td>
                                            <td>@sub.TimetableSlot?.StartTime:HH:mm – @sub.TimetableSlot?.EndTime:HH:mm</td>
                                            <td>@sub.TimetableSlot?.Subject?.Name</td>
                                            <td>@sub.TimetableSlot?.ClassBatch?.BatchName</td>
                                            <td>@sub.SubstituteTeacher?.FullName</td>
                                            <td>@sub.Reason</td>
                                            <td><small>@sub.ApprovedBy</small></td>
                                            <td class="text-center">
                                                <form method="post" asp-page-handler="Delete" style="display: inline;">
                                                    <input type="hidden" name="id" value="@sub.Id">
                                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this record?')">Delete</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No substitution records found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedSlotId = null;

        async function loadAbsentTeacherSlots() {
            const date = document.getElementById('date').value;
            const teacherId = document.getElementById('absentTeacherId').value;

            if (!date || !teacherId) return;

            try {
                const response = await fetch(`?handler=AbsentTeacherSlots&teacherId=${teacherId}&date=${date}`);
                const slots = await response.json();

                const slotsList = document.getElementById('slotsList');
                slotsList.innerHTML = '';

                if (slots.length === 0) {
                    slotsList.innerHTML = '<div class="alert alert-info">No slots found for this teacher on this date.</div>';
                    document.getElementById('slotsContainer').style.display = 'block';
                    document.getElementById('substitutesContainer').style.display = 'none';
                    document.getElementById('submitBtn').disabled = true;
                } else {
                    slots.forEach(slot => {
                        const card = document.createElement('div');
                        card.className = 'card mb-2 cursor-pointer';
                        card.style.cursor = 'pointer';
                        card.innerHTML = `
                            <div class="card-body p-3">
                                <div class="row align-items-center">
                                    <div class="col">
                                        <strong>${slot.classBatch}</strong> | ${slot.subject} | ${slot.time} | Room ${slot.room}
                                    </div>
                                    <div class="col-auto">
                                        <input type="radio" name="slotSelect" value="${slot.id}" class="form-check-input" onchange="selectSlot(${slot.id}, '${slot.time}')">
                                    </div>
                                </div>
                            </div>
                        `;
                        slotsList.appendChild(card);
                    });

                    document.getElementById('slotsContainer').style.display = 'block';
                }
            } catch (e) {
                console.error('Error loading slots:', e);
            }
        }

        async function selectSlot(slotId, slotTime) {
            selectedSlotId = slotId;

            try {
                const response = await fetch(`?handler=AvailableSubstitutes&slotId=${slotId}`);
                const substitutes = await response.json();

                const substituteSelect = document.getElementById('substituteTeacherId');
                substituteSelect.innerHTML = '<option value="">-- Select Substitute --</option>';

                if (substitutes.length === 0) {
                    substituteSelect.innerHTML = '<option value="">No available substitutes for this slot</option>';
                    document.getElementById('substitutesContainer').style.display = 'block';
                    document.getElementById('submitBtn').disabled = true;
                } else {
                    substitutes.forEach(teacher => {
                        const option = document.createElement('option');
                        option.value = teacher.id;
                        option.textContent = `${teacher.name} (${teacher.initials}) - ${teacher.department}`;
                        substituteSelect.appendChild(option);
                    });

                    document.getElementById('substitutesContainer').style.display = 'block';
                    document.getElementById('submitBtn').disabled = false;

                    // Set hidden field
                    const hiddenField = document.querySelector('input[name="Input.TimetableSlotId"]');
                    if (!hiddenField) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'Input.TimetableSlotId';
                        input.value = slotId;
                        document.querySelector('form').appendChild(input);
                    } else {
                        hiddenField.value = slotId;
                    }
                }
            } catch (e) {
                console.error('Error loading substitutes:', e);
            }
        }
    </script>
}
