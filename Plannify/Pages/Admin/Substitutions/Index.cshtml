@page "/Admin/Substitutions"
@model Plannify.Pages.Admin.Substitutions.IndexModel
@{
    ViewData["Title"] = "Substitutions";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Record Substitution Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-8">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">person_add</span>
        <h3 class="text-lg font-semibold text-on-surface">Record Substitution</h3>
    </div>
    
    <form method="post" asp-page-handler="Assign" class="grid grid-cols-3 gap-4">
        @Html.AntiForgeryToken()
        
        <div>
            <label for="date" class="block text-sm font-medium text-on-surface mb-2">Date</label>
            <input type="date" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="date" asp-for="Input.Date" required onchange="loadAbsentTeacherSlots()">
        </div>
        
        <div>
            <label for="absentTeacherId" class="block text-sm font-medium text-on-surface mb-2">Absent Teacher</label>
            <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="absentTeacherId" asp-for="Input.AbsentTeacherId" asp-items="Model.Teachers" required onchange="loadAbsentTeacherSlots()">
                <option value="">-- Select Teacher --</option>
            </select>
        </div>
        
        <div>
            <label for="substituteTeacherId" class="block text-sm font-medium text-on-surface mb-2">Substitute Teacher</label>
            <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="substituteTeacherId" asp-for="Input.SubstituteTeacherId" required>
                <option value="">-- Select Substitute --</option>
            </select>
        </div>
        
        <div>
            <label for="slotId" class="block text-sm font-medium text-on-surface mb-2">Slot</label>
            <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="slotId" name="slotId">
                <option value="">-- Select Slot --</option>
            </select>
        </div>
        
        <div>
            <label for="reason" class="block text-sm font-medium text-on-surface mb-2">Reason</label>
            <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="reason" asp-for="Input.Reason" placeholder="Medical leave, Conference..." />
        </div>
        
        <div class="flex items-end">
            <button type="submit" class="w-full px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">
                <span class="material-symbols-outlined align-middle">add_circle</span> Record
            </button>
        </div>
    </form>
</div>

<!-- Substitution History -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">history</span>
        <h3 class="text-lg font-semibold text-on-surface">Substitution History</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.SubstitutionHistory.Count record(s)</div>
    </div>
    
    @if (Model.SubstitutionHistory.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Date</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Absent Teacher</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Slot</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Subject</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Class</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Substitute</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Reason</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in Model.SubstitutionHistory)
                    {
                        <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                            <td class="px-8 py-5 text-sm text-on-surface">@sub.Date.ToString("dd MMM yyyy")</td>
                            <td class="px-4 py-5 text-sm font-medium text-on-surface">@sub.OriginalTeacher?.FullName</td>
                            <td class="px-4 py-5 text-sm text-on-surface">@sub.TimetableSlot?.StartTime.ToString("HH:mm") – @sub.TimetableSlot?.EndTime.ToString("HH:mm")</td>
                            <td class="px-4 py-5 text-sm text-on-surface">@sub.TimetableSlot?.Subject?.Name</td>
                            <td class="px-4 py-5 text-sm text-on-surface">@sub.TimetableSlot?.ClassBatch?.BatchName</td>
                            <td class="px-4 py-5 text-sm font-medium text-on-surface">@sub.SubstituteTeacher?.FullName</td>
                            <td class="px-4 py-5 text-sm text-on-surface-variant">@sub.Reason</td>
                            <td class="px-4 py-5">
                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <form method="post" asp-page-handler="Delete" style="display: inline;">
                                        <input type="hidden" name="id" value="@sub.Id">
                                        <button type="submit" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" onclick="return confirm('Delete this record?')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No substitution records found.</p>
        </div>
    }
</div>
</div>

@section Scripts {
    <script>
        let selectedSlotId = null;

        async function loadAbsentTeacherSlots() {
            const date = document.getElementById('date').value;
            const teacherId = document.getElementById('absentTeacherId').value;

            if (!date || !teacherId) return;

            try {
                const response = await fetch(`?handler=AbsentTeacherSlots&teacherId=${teacherId}&date=${date}`);
                const slots = await response.json();

                const slotsList = document.getElementById('slotsList');
                slotsList.innerHTML = '';

                if (slots.length === 0) {
                    slotsList.innerHTML = '<div class="alert alert-info">No slots found for this teacher on this date.</div>';
                    document.getElementById('slotsContainer').style.display = 'block';
                    document.getElementById('substitutesContainer').style.display = 'none';
                    document.getElementById('submitBtn').disabled = true;
                } else {
                    slots.forEach(slot => {
                        const card = document.createElement('div');
                        card.className = 'card mb-2 cursor-pointer';
                        card.style.cursor = 'pointer';
                        card.innerHTML = `
                            <div class="card-body p-3">
                                <div class="row align-items-center">
                                    <div class="col">
                                        <strong>${slot.classBatch}</strong> | ${slot.subject} | ${slot.time} | Room ${slot.room}
                                    </div>
                                    <div class="col-auto">
                                        <input type="radio" name="slotSelect" value="${slot.id}" class="form-check-input" onchange="selectSlot(${slot.id}, '${slot.time}')">
                                    </div>
                                </div>
                            </div>
                        `;
                        slotsList.appendChild(card);
                    });

                    document.getElementById('slotsContainer').style.display = 'block';
                }
            } catch (e) {
                console.error('Error loading slots:', e);
            }
        }

        async function selectSlot(slotId, slotTime) {
            selectedSlotId = slotId;

            try {
                const response = await fetch(`?handler=AvailableSubstitutes&slotId=${slotId}`);
                const substitutes = await response.json();

                const substituteSelect = document.getElementById('substituteTeacherId');
                substituteSelect.innerHTML = '<option value="">-- Select Substitute --</option>';

                if (substitutes.length === 0) {
                    substituteSelect.innerHTML = '<option value="">No available substitutes for this slot</option>';
                    document.getElementById('substitutesContainer').style.display = 'block';
                    document.getElementById('submitBtn').disabled = true;
                } else {
                    substitutes.forEach(teacher => {
                        const option = document.createElement('option');
                        option.value = teacher.id;
                        option.textContent = `${teacher.name} (${teacher.initials}) - ${teacher.department}`;
                        substituteSelect.appendChild(option);
                    });

                    document.getElementById('substitutesContainer').style.display = 'block';
                    document.getElementById('submitBtn').disabled = false;

                    // Set hidden field
                    const hiddenField = document.querySelector('input[name="Input.TimetableSlotId"]');
                    if (!hiddenField) {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'Input.TimetableSlotId';
                        input.value = slotId;
                        document.querySelector('form').appendChild(input);
                    } else {
                        hiddenField.value = slotId;
                    }
                }
            } catch (e) {
                console.error('Error loading substitutes:', e);
            }
        }
    </script>
}
