@page "{yearId:int}"
@model Plannify.Pages.Admin.AcademicYears.SemestersModel
@{
    ViewData["Title"] = "Semesters";
    ViewData["Section"] = Model.AcademicYear?.YearLabel ?? "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Back Button and Header -->
<div class="flex items-center justify-between mb-6">
    <div>
        <h2 class="text-2xl font-bold text-on-surface">Semesters for @Model.AcademicYear?.YearLabel</h2>
        <p class="text-on-surface-variant text-sm mt-1">Managing semesters for academic year</p>
    </div>
    <a href="/Admin/AcademicYears/" class="px-6 py-3 bg-surface-container-low text-on-surface-variant font-medium rounded-xl hover:bg-surface-container-low/80 transition-colors flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        Back
    </a>
</div>

@if (Model.AcademicYear == null)
{
    <div class="bg-error-container rounded-2xl p-6 border border-error/20">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-error text-2xl">warning</span>
            <p class="text-on-error-container">Academic year not found.</p>
        </div>
    </div>
    return;
}

<!-- Add Semester Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Semester</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label for="NewSem_Name" class="block text-sm font-medium text-on-surface mb-2">Semester Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSem_Name" asp-for="NewSemester.Name" placeholder="e.g., Odd Semester" required>
                <span asp-validation-for="NewSemester.Name" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSem_Number" class="block text-sm font-medium text-on-surface mb-2">Semester Number (1-8)</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSem_Number" asp-for="NewSemester.SemesterNumber" min="1" max="8" required>
                <span asp-validation-for="NewSemester.SemesterNumber" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Semester</button>
        </div>
    </form>
</div>

<!-- Semesters Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">schedule</span>
        <h3 class="text-lg font-semibold text-on-surface">Semesters List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.Semesters.Count record(s)</div>
    </div>
    
    @if (Model.Semesters.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Semester Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Semester Number</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Status</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Slots</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var sem in Model.Semesters)
                        {
                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@sem.Name</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed font-bold rounded-full">Sem @sem.SemesterNumber</span></td>
                                <td class="px-4 py-5">
                                    @if (sem.IsActive)
                                    {
                                        <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold text-xs rounded-full">✓ Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 bg-on-surface-variant/10 text-on-surface-variant font-bold text-xs rounded-full">Inactive</span>
                                    }
                                </td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-secondary-fixed text-on-secondary-fixed font-bold rounded-full">@(Model.SlotCounts.ContainsKey(sem.Id) ? Model.SlotCounts[sem.Id] : 0)</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        @if (!sem.IsActive)
                                        {
                                            <form method="post" asp-page-handler="SetActive" asp-route-id="@sem.Id" style="display: inline;">
                                                <button type="submit" class="p-2 rounded-lg hover:bg-tertiary/10 text-tertiary transition-colors" title="Set as Active">
                                                    <span class="material-symbols-outlined text-lg">check_circle</span>
                                                </button>
                                            </form>
                                        }
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@sem.Id', '@sem.Name')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No semesters found for this academic year.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function showDeleteModal(id, semesterName) {
            const confirmed = confirm(`Delete semester "${semesterName}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
