@page "{yearId:int}"
@model Plannify.Pages.Admin.AcademicYears.SemestersModel
@{
    ViewData["Title"] = "Manage Semesters";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="card-title mb-0">📚 Semesters for @Model.AcademicYear?.YearLabel</h2>
            <p class="text-muted mb-0">Managing semesters for academic year</p>
        </div>
        <a href="/Admin/AcademicYears/" class="btn btn-outline-primary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.AcademicYear == null)
    {
        <div class="alert alert-warning">
            Academic year not found.
        </div>
        return;
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Semester</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Add">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="NewSemester.Name" class="form-label">Semester Name</label>
                        <input type="text" asp-for="NewSemester.Name" class="form-control" placeholder="e.g., Odd Semester" required />
                        <span asp-validation-for="NewSemester.Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NewSemester.SemesterNumber" class="form-label">Semester Number (1-8)</label>
                        <input type="number" asp-for="NewSemester.SemesterNumber" class="form-control" min="1" max="8" required />
                        <span asp-validation-for="NewSemester.SemesterNumber" class="text-danger"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Semester
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">Semesters List</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%">#</th>
                        <th>Semester Name</th>
                        <th>Semester Number</th>
                        <th>Status</th>
                        <th>Slots</th>
                        <th style="width: 15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Semesters.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No semesters found for this academic year.
                            </td>
                        </tr>
                    }
                    @foreach (var sem in Model.Semesters)
                    {
                        <tr>
                            <td><strong>@(Model.Semesters.IndexOf(sem) + 1)</strong></td>
                            <td>@sem.Name</td>
                            <td>
                                <span class="badge bg-primary">Sem @sem.SemesterNumber</span>
                            </td>
                            <td>
                                @if (sem.IsActive)
                                {
                                    <span class="badge bg-success">✓ Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@(Model.SlotCounts.ContainsKey(sem.Id) ? Model.SlotCounts[sem.Id] : 0)</span>
                            </td>
                            <td>
                                @if (!sem.IsActive)
                                {
                                    <form method="post" asp-page-handler="SetActive" asp-route-id="@sem.Id" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-success" title="Set as Active">
                                            <i class="bi bi-check-circle"></i> Activate
                                        </button>
                                    </form>
                                }
                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                        onclick="setDeleteData(@sem.Id, '@sem.Name')" title="Delete Semester">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Delete Semester</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete semester <strong id="deleteSemesterName"></strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="Delete" style="display: inline;">
                    <input type="hidden" id="deleteSemesterId" name="id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function setDeleteData(id, semesterName) {
        document.getElementById('deleteSemesterId').value = id;
        document.getElementById('deleteSemesterName').textContent = semesterName;
    }
</script>
