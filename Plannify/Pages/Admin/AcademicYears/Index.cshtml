@page
@model Plannify.Pages.Admin.AcademicYears.IndexModel
@{
    ViewData["Title"] = "Academic Years";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="card-title mb-0">📅 Academic Years Management</h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Add New Academic Year</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-page-handler="Add">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="NewAcademicYear.YearLabel" class="form-label">Year Label (e.g., 2025-26)</label>
                        <input type="text" asp-for="NewAcademicYear.YearLabel" class="form-control" placeholder="2025-26" required />
                        <span asp-validation-for="NewAcademicYear.YearLabel" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NewAcademicYear.StartDate" class="form-label">Start Date</label>
                        <input type="date" asp-for="NewAcademicYear.StartDate" class="form-control" required />
                        <span asp-validation-for="NewAcademicYear.StartDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NewAcademicYear.EndDate" class="form-label">End Date</label>
                        <input type="date" asp-for="NewAcademicYear.EndDate" class="form-control" required />
                        <span asp-validation-for="NewAcademicYear.EndDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add Academic Year
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">Academic Years List</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%">#</th>
                        <th>Year Label</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Semesters</th>
                        <th style="width: 15%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AcademicYears.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No academic years found. Create one to get started.
                            </td>
                        </tr>
                    }
                    @foreach (var year in Model.AcademicYears)
                    {
                        <tr>
                            <td><strong>@Model.AcademicYears.IndexOf(year) + 1</strong></td>
                            <td>@year.YearLabel</td>
                            <td>@year.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@year.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (year.IsActive)
                                {
                                    <span class="badge bg-success">✓ Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@(Model.SemesterCounts.ContainsKey(year.Id) ? Model.SemesterCounts[year.Id] : 0)</span>
                            </td>
                            <td>
                                @if (!year.IsActive)
                                {
                                    <form method="post" asp-page-handler="SetActive" asp-route-id="@year.Id" style="display: inline;">
                                        <button type="submit" class="btn btn-sm btn-success" title="Set as Active">
                                            <i class="bi bi-check-circle"></i> Activate
                                        </button>
                                    </form>
                                }
                                <a href="/Admin/AcademicYears/Semesters?yearId=@year.Id" class="btn btn-sm btn-info" title="Manage Semesters">
                                    <i class="bi bi-gear"></i> Semesters
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                        onclick="setDeleteData(@year.Id, '@year.YearLabel')" title="Delete Academic Year">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Delete Academic Year</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete academic year <strong id="deleteYearLabel"></strong>?</p>
                <p class="text-muted small">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-page-handler="Delete" style="display: inline;">
                    <input type="hidden" id="deleteYearId" name="id" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function setDeleteData(id, yearLabel) {
        document.getElementById('deleteYearId').value = id;
        document.getElementById('deleteYearLabel').textContent = yearLabel;
    }
</script>
