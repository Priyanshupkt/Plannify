@page "/Admin/AcademicYears"
@model Plannify.Pages.Admin.AcademicYears.IndexModel
@{
    ViewData["Title"] = "Academic Years";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Add Academic Year Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Academic Year</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label for="NewYear_Label" class="block text-sm font-medium text-on-surface mb-2">Year Label (e.g., 2025-26)</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewYear_Label" asp-for="NewAcademicYear.YearLabel" placeholder="2025-26" required>
                <span asp-validation-for="NewAcademicYear.YearLabel" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewYear_Start" class="block text-sm font-medium text-on-surface mb-2">Start Date</label>
                <input type="date" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewYear_Start" asp-for="NewAcademicYear.StartDate" required>
                <span asp-validation-for="NewAcademicYear.StartDate" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewYear_End" class="block text-sm font-medium text-on-surface mb-2">End Date</label>
                <input type="date" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewYear_End" asp-for="NewAcademicYear.EndDate" required>
                <span asp-validation-for="NewAcademicYear.EndDate" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Academic Year</button>
        </div>
    </form>
</div>

<!-- Academic Years Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">calendar_month</span>
        <h3 class="text-lg font-semibold text-on-surface">Academic Years List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.AcademicYears.Count record(s)</div>
    </div>
    
    @if (Model.AcademicYears.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Year Label</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Start Date</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">End Date</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Status</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Semesters</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var year in Model.AcademicYears)
                        {
                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@year.YearLabel</td>
                                <td class="px-4 py-5 text-sm text-on-surface">@year.StartDate.ToString("dd MMM yyyy")</td>
                                <td class="px-4 py-5 text-sm text-on-surface">@year.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="px-4 py-5">
                                    @if (year.IsActive)
                                    {
                                        <span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold text-xs rounded-full">✓ Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 bg-on-surface-variant/10 text-on-surface-variant font-bold text-xs rounded-full">Inactive</span>
                                    }
                                </td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-secondary-fixed text-on-secondary-fixed font-bold rounded-full">@(Model.SemesterCounts.ContainsKey(year.Id) ? Model.SemesterCounts[year.Id] : 0)</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        @if (!year.IsActive)
                                        {
                                            <form method="post" asp-page-handler="SetActive" asp-route-id="@year.Id" style="display: inline;">
                                                <button type="submit" class="p-2 rounded-lg hover:bg-tertiary/10 text-tertiary transition-colors" title="Set as Active">
                                                    <span class="material-symbols-outlined text-lg">check_circle</span>
                                                </button>
                                            </form>
                                        }
                                        <a href="/Admin/AcademicYears/Semesters?yearId=@year.Id" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" title="Manage Semesters">
                                            <span class="material-symbols-outlined text-lg">settings</span>
                                        </a>
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@year.Id', '@year.YearLabel')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No academic years found. Create one to get started.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function showDeleteModal(id, yearLabel) {
            const confirmed = confirm(`Delete academic year "${yearLabel}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
