@page
@model Plannify.Pages.Admin.Timetable.ByTeacherModel
@{
    ViewData["Title"] = "Timetable by Teacher";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-lg-8">
            <h2>Timetable by Teacher</h2>
        </div>
    </div>

    <!-- Top Controls -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="teacherSelect" class="form-label">Select Teacher</label>
                    <select class="form-select" id="teacherSelect" onchange="changeTeacher()">
                        <option value="">-- Select Teacher --</option>
                        @foreach (var teacher in Model.Teachers)
                        {
                            <option value="@teacher.Value" @(teacher.Value == Model.CurrentTeacher?.Id.ToString() ? "selected" : "")>@teacher.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="semesterSelect" class="form-label">Select Semester</label>
                    <select class="form-select" id="semesterSelect" onchange="changeSemester()">
                        <option value="">-- Select Semester --</option>
                        @foreach (var sem in Model.Semesters)
                        {
                            <option value="@sem.Value" @(sem.Value == Model.CurrentSemester?.Id.ToString() ? "selected" : "")>@sem.Text</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="d-grid gap-2 d-lg-flex justify-content-lg-end" style="height: 100%; align-items: flex-end;">
                <form method="post" asp-page-handler="PrintPdf" style="display: inline;">
                    <input type="hidden" name="teacherId" value="@Model.CurrentTeacher?.Id">
                    <input type="hidden" name="semesterId" value="@Model.CurrentSemester?.Id">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-print"></i> Print PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Left: Grid -->
        <div class="col-lg-8">
            @if (Model.CurrentTeacher != null && Model.CurrentSemester != null && Model.TimeRanges.Count > 0)
            {
                <div class="card">
                    <div class="card-body p-0" style="overflow-x: auto;">
                        <table class="table table-bordered table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="min-width: 100px;">Time</th>
                                    @foreach (var day in Model.Days)
                                    {
                                        <th class="text-center" style="min-width: 120px;">@day.Substring(0, 3)</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var timeRange in Model.TimeRanges)
                                {
                                    <tr>
                                        <td class="text-center text-nowrap fw-bold">
                                            <small>@timeRange</small>
                                        </td>
                                        @foreach (var day in Model.Days)
                                        {
                                            var slot = Model.Grid[day][timeRange];
                                            string bgClass = "bg-light";
                                            
                                            if (slot != null)
                                            {
                                                bgClass = slot.SlotType switch
                                                {
                                                    "Theory" => "bg-white",
                                                    "Lab" => "tg-lab",
                                                    "GAP" => "tg-gap",
                                                    "Elective" => "bg-light-purple",
                                                    _ => "bg-light"
                                                };
                                            }

                                            <td class="@bgClass text-center align-middle" style="min-height: 60px;">
                                                @if (slot != null)
                                                {
                                                    <div class="small">
                                                        <strong>@slot.Subject?.Name</strong><br>
                                                        <span class="text-muted">@slot.ClassBatch?.BatchName</span><br>
                                                        <span class="text-muted">@slot.Room?.RoomNumber</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Free</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Select a teacher and semester to view the timetable.
                </div>
            }
        </div>

        <!-- Right: Workload Panel -->
        @if (Model.CurrentTeacher != null)
        {
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">Weekly Workload</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span><strong>Teaching Hours</strong></span>
                                <span class="badge bg-primary">@Model.TotalTeachingHours / @Model.MaxWeeklyHours hrs</span>
                            </div>
                            @{
                                double percentage = Model.MaxWeeklyHours > 0 ? (double)Model.TotalTeachingHours / Model.MaxWeeklyHours * 100 : 0;
                                string progressClass = percentage <= 75 ? "bg-success" : percentage <= 90 ? "bg-warning" : "bg-danger";
                            }
                            <div class="progress" role="progressbar">
                                <div class="progress-bar @progressClass" style="width: @Math.Min(percentage, 100)%"></div>
                            </div>
                        </div>

                        <hr>

                        <div class="mb-3">
                            <h6 class="mb-3">Hours Breakdown</h6>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">Theory</span>
                                    <span class="badge bg-light text-dark">@Model.TheoryHours hrs</span>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">Lab</span>
                                    <span class="badge tg-lab text-dark">@Model.LabHours hrs</span>
                                </div>
                            </div>
                            <div class="mb-2">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small">GAP</span>
                                    <span class="badge tg-gap text-dark">@Model.GapHours hrs</span>
                                </div>
                            </div>
                        </div>

                        <hr>

                        @if (Model.DaysWithNoClasses.Count > 0)
                        {
                            <div>
                                <h6 class="mb-2">Free Days</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var day in Model.DaysWithNoClasses)
                                    {
                                        <span class="badge bg-success">@day.Substring(0, 3)</span>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">
                                <small>No free days this week.</small>
                            </div>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Teacher Info</h6>
                    </div>
                    <div class="card-body small">
                        <p class="mb-2">
                            <strong>Name:</strong> @Model.CurrentTeacher.FullName
                        </p>
                        <p class="mb-2">
                            <strong>Initials:</strong> <span class="badge bg-info">@Model.CurrentTeacher.Initials</span>
                        </p>
                        <p class="mb-2">
                            <strong>Employee Code:</strong> @Model.CurrentTeacher.EmployeeCode
                        </p>
                        <p class="mb-2">
                            <strong>Designation:</strong> @Model.CurrentTeacher.Designation
                        </p>
                        <p class="mb-0">
                            <strong>Max Hours/Week:</strong> @Model.MaxWeeklyHours
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function changeTeacher() {
            const teacherId = document.getElementById('teacherSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (teacherId && semesterId) {
                window.location = `?teacherId=${teacherId}&semesterId=${semesterId}`;
            }
        }

        function changeSemester() {
            const teacherId = document.getElementById('teacherSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (teacherId && semesterId) {
                window.location = `?teacherId=${teacherId}&semesterId=${semesterId}`;
            }
        }
    </script>
}
