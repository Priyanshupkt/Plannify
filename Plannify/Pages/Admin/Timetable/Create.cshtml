@page
@model Plannify.Pages.Admin.Timetable.CreateModel
@{
    ViewData["Title"] = "Create Timetable Slot";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Grid Layout: 2 Columns -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- LEFT PANEL: Slot Entry Form (1 col) -->
        <div class="lg:col-span-1">
            <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm">
                <div class="p-6">
                    <form method="post" asp-page-handler="Add">
                        @Html.AntiForgeryToken()

                        <!-- Section 1: Context -->
                        <div class="mb-6">
                            <h6 class="text-sm font-bold text-on-surface mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">calendar_month</span>
                                Context
                            </h6>
                            
                            <div class="mb-4">
                                <label for="semesterId" class="block text-xs font-bold text-on-surface-variant mb-2">Semester</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="semesterId" asp-for="Input.SemesterId" asp-items="Model.Semesters" required>
                                    <option value="">-- Select Semester --</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label for="classBatchId" class="block text-xs font-bold text-on-surface-variant mb-2">Class Batch</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="classBatchId" asp-for="Input.ClassBatchId" asp-items="Model.ClassBatches" required onchange="loadClassGrid()">
                                    <option value="">-- Select Class --</option>
                                </select>
                            </div>
                        </div>

                        <!-- Section 2: Slot Details -->
                        <div class="mb-6 pb-6 border-b border-outline-variant/20">
                            <h6 class="text-sm font-bold text-on-surface mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">schedule</span>
                                Slot Details
                            </h6>

                            <div class="mb-4">
                                <label for="day" class="block text-xs font-bold text-on-surface-variant mb-2">Day</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="day" asp-for="Input.Day" asp-items="Model.Days" required>
                                    <option value="">-- Select Day --</option>
                                </select>
                            </div>

                            <div class="grid grid-cols-2 gap-3 mb-4">
                                <div>
                                    <label for="startTime" class="block text-xs font-bold text-on-surface-variant mb-2">Start Time</label>
                                    <input type="time" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="startTime" asp-for="Input.StartTime" required>
                                </div>
                                <div>
                                    <label for="endTime" class="block text-xs font-bold text-on-surface-variant mb-2">End Time</label>
                                    <input type="time" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="endTime" asp-for="Input.EndTime" required onblur="checkConflicts()">
                                </div>
                            </div>

                            <!-- Conflict Status Indicator -->
                            <div id="conflictStatus" class="hidden mb-4 p-3 rounded-lg text-sm flex items-center gap-2">
                                <!-- Dynamically populated by JavaScript -->
                            </div>

                            <!-- Suggested Times Section (appears only when conflict detected) -->
                            <div id="suggestionsContainer" class="hidden mb-6 pb-4 bg-info-container/20 border border-info/30 rounded-xl p-4">
                                <div class="flex items-center gap-2 mb-3">
                                    <span class="material-symbols-outlined text-info text-base">lightbulb</span>
                                    <h6 class="text-sm font-bold text-on-surface">Suggested Available Times</h6>
                                </div>
                                <div id="suggestionsList" class="space-y-2">
                                    <!-- Dynamically populated by JavaScript -->
                                </div>
                            </div>

                            <!-- Slot Type Radio Buttons -->
                            <label class="block text-xs font-bold text-on-surface-variant mb-3">Slot Type</label>
                            <div class="grid grid-cols-2 gap-2 mb-4">
                                <label class="relative flex items-center">
                                    <input type="radio" name="Input.SlotType" value="Theory" asp-for="Input.SlotType" onchange="updateSlotTypeVisibility()" checked class="sr-only peer" id="slotTheory">
                                    <span class="w-full px-3 py-2 bg-surface-container-low border border-outline-variant/20 rounded-lg text-xs font-bold text-on-surface-variant cursor-pointer peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-all">Theory</span>
                                </label>
                                <label class="relative flex items-center">
                                    <input type="radio" name="Input.SlotType" value="Lab" asp-for="Input.SlotType" onchange="updateSlotTypeVisibility()" class="sr-only peer" id="slotLab">
                                    <span class="w-full px-3 py-2 bg-surface-container-low border border-outline-variant/20 rounded-lg text-xs font-bold text-on-surface-variant cursor-pointer peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-all">Lab</span>
                                </label>
                                <label class="relative flex items-center">
                                    <input type="radio" name="Input.SlotType" value="GAP" asp-for="Input.SlotType" onchange="updateSlotTypeVisibility()" class="sr-only peer" id="slotGap">
                                    <span class="w-full px-3 py-2 bg-surface-container-low border border-outline-variant/20 rounded-lg text-xs font-bold text-on-surface-variant cursor-pointer peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-all">GAP</span>
                                </label>
                                <label class="relative flex items-center">
                                    <input type="radio" name="Input.SlotType" value="Elective" asp-for="Input.SlotType" onchange="updateSlotTypeVisibility()" class="sr-only peer" id="slotElective">
                                    <span class="w-full px-3 py-2 bg-surface-container-low border border-outline-variant/20 rounded-lg text-xs font-bold text-on-surface-variant cursor-pointer peer-checked:bg-primary peer-checked:text-on-primary peer-checked:border-primary transition-all">Elective</span>
                                </label>
                            </div>
                        </div>

                        <!-- Section 3: Assignment (Hidden if GAP) -->
                        <div class="mb-6 pb-6 border-b border-outline-variant/20" id="assignmentSection">
                            <h6 class="text-sm font-bold text-on-surface mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">person</span>
                                Assignment
                            </h6>

                            <div class="mb-4">
                                <label for="teacherId" class="block text-xs font-bold text-on-surface-variant mb-2">Teacher</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="teacherId" asp-for="Input.TeacherId" asp-items="Model.Teachers">
                                    <option value="">-- Select Teacher --</option>
                                </select>
                                <small class="text-xs text-on-surface-variant mt-1 block" id="teacherHours"></small>
                            </div>

                            <div class="mb-4">
                                <label for="subjectId" class="block text-xs font-bold text-on-surface-variant mb-2">Subject</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="subjectId" asp-for="Input.SubjectId" asp-items="Model.Subjects">
                                    <option value="">-- Select Subject --</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label for="roomId" class="block text-xs font-bold text-on-surface-variant mb-2">Room</label>
                                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="roomId" asp-for="Input.RoomId" asp-items="Model.Rooms">
                                    <option value="">-- Select Room --</option>
                                </select>
                                <div class="mt-3">
                                    <span id="roomAvailability" class="px-3 py-1 bg-green-50 text-green-700 text-xs font-bold rounded-full border border-green-200">Available</span>
                                </div>
                            </div>
                        </div>

                        <!-- Section 4: Lab Session -->
                        <div class="mb-6 pb-6 border-b border-outline-variant/20" id="labSection" style="display: none;">
                            <h6 class="text-sm font-bold text-on-surface mb-4 flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">science</span>
                                Lab Session
                            </h6>

                            <label class="flex items-center mb-4">
                                <input type="checkbox" class="w-4 h-4 rounded border-outline-variant bg-surface-container-low" id="isMultiPeriodLab" asp-for="Input.IsMultiPeriodLab" onchange="updateLabTagVisibility()">
                                <span class="ml-3 text-xs font-bold text-on-surface">Is Multi-Period Lab</span>
                            </label>

                            <div id="labTagSection" style="display: none;" class="mb-4">
                                <label for="labGroupTag" class="block text-xs font-bold text-on-surface-variant mb-2">Lab Group Tag</label>
                                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="labGroupTag" asp-for="Input.LabGroupTag" placeholder="e.g., Lab-Group-A">
                            </div>
                        </div>

                        <!-- Conflict Warning Area -->
                        <div class="mb-6" id="conflictWarningArea" style="display: none;">
                            <div class="bg-warning/10 border border-warning/30 rounded-2xl p-4">
                                <h6 class="text-sm font-bold text-warning mb-3 flex items-center gap-2">
                                    <span class="material-symbols-outlined text-base">warning</span>
                                    Conflicts Detected
                                </h6>
                                <ul id="conflictsList" class="mb-3 space-y-1 text-xs text-on-surface"></ul>
                                <label class="flex items-center">
                                    <input type="checkbox" class="w-4 h-4 rounded border-outline-variant bg-surface-container-low" id="ignoreConflicts" asp-for="Input.IgnoreConflicts">
                                    <span class="ml-3 text-xs font-bold text-on-surface">I understand the conflict, save anyway</span>
                                </label>
                            </div>
                        </div>

                        <!-- Submit/Clear Buttons -->
                        <div class="space-y-2">
                            <button type="submit" class="w-full bg-primary hover:bg-primary-container text-on-primary px-6 py-3 rounded-xl font-bold shadow-lg shadow-primary/20 transition-all">
                                <span class="material-symbols-outlined inline mr-2 -mt-1">add_circle</span>
                                Add Slot
                            </button>
                            <button type="reset" class="w-full bg-surface-container-high hover:bg-surface-container-high/80 text-on-surface px-6 py-3 rounded-xl font-bold transition-all">
                                Clear Form
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT PANEL: Class Grid Preview (2 cols) -->
        <div class="lg:col-span-2">
            <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm">
                <div class="px-6 py-4 border-b border-outline-variant/20 bg-surface-container-low/50">
                    <h6 class="text-sm font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-base">grid_view</span>
                        Class Timetable Preview
                    </h6>
                </div>
                <div class="p-6">
                    <div id="gridPreview">
                        <p class="text-sm text-on-surface-variant">Select a class and semester to view the timetable.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateSlotTypeVisibility() {
            const slotType = document.querySelector('input[name="Input.SlotType"]:checked').value;
            const assignmentSection = document.getElementById('assignmentSection');
            const labSection = document.getElementById('labSection');

            if (slotType === 'GAP') {
                assignmentSection.style.display = 'none';
                labSection.style.display = 'none';
            } else {
                assignmentSection.style.display = 'block';
                if (slotType === 'Lab') {
                    labSection.style.display = 'block';
                } else {
                    labSection.style.display = 'none';
                }
            }
        }

        function updateLabTagVisibility() {
            const isMultiPeriod = document.getElementById('isMultiPeriodLab').checked;
            document.getElementById('labTagSection').style.display = isMultiPeriod ? 'block' : 'none';
        }

        function loadClassGrid() {
            const classId = document.getElementById('classBatchId').value;
            const semesterId = document.getElementById('semesterId').value;

            if (!classId || !semesterId) {
                document.getElementById('gridPreview').innerHTML = '<p class="text-muted">Select both class and semester.</p>';
                return;
            }

            fetch(`?handler=ClassGrid&classId=${classId}&semesterId=${semesterId}`)
                .then(r => r.json())
                .then(slots => renderGrid(slots))
                .catch(e => console.error('Error loading grid:', e));
        }

        function renderGrid(slots) {
            if (!slots || slots.length === 0) {
                document.getElementById('gridPreview').innerHTML = '<p class="text-muted">No slots yet for this class.</p>';
                return;
            }

            const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
            const timeRanges = [...new Set(slots.map(s => `${s.startTime}-${s.endTime}`))].sort();

            let html = '<table class="table table-bordered table-sm">';
            html += '<thead><tr><th>Time</th>';
            days.forEach(day => html += `<th>${day.substring(0, 3)}</th>`);
            html += '</tr></thead><tbody>';

            timeRanges.forEach(timeRange => {
                html += `<tr><td class="text-nowrap"><small>${timeRange}</small></td>`;
                days.forEach(day => {
                    const slot = slots.find(s => s.day === day && `${s.startTime}-${s.endTime}` === timeRange);
                    if (slot) {
                        const bgClass = slot.slotType === 'Theory' ? 'bg-white' : 
                                      slot.slotType === 'Lab' ? 'tg-lab' :
                                      slot.slotType === 'GAP' ? 'tg-gap' : 'bg-light';
                        html += `<td class="${bgClass}"><small>${slot.subject}<br>${slot.teacher}<br>${slot.room}</small></td>`;
                    } else {
                        html += '<td class="bg-light text-center"><small>Free</small></td>';
                    }
                });
                html += '</tr>';
            });

            html += '</tbody></table>';
            document.getElementById('gridPreview').innerHTML = html;
        }

        async function checkConflicts() {
            const teacherId = document.getElementById('teacherId').value || 0;
            const roomId = document.getElementById('roomId').value || 0;
            const classId = document.getElementById('classBatchId').value;
            const day = document.getElementById('day').value;
            const start = document.getElementById('startTime').value;
            const end = document.getElementById('endTime').value;
            const semesterId = document.getElementById('semesterId').value;

            if (!classId || !day || !start || !end || !semesterId) return;

            fetch(`?handler=CheckConflicts&teacherId=${teacherId}&roomId=${roomId}&classId=${classId}&day=${day}&start=${start}&end=${end}&semesterId=${semesterId}`)
                .then(r => r.json())
                .then(conflicts => {
                    const warningArea = document.getElementById('conflictWarningArea');
                    const conflictsList = document.getElementById('conflictsList');

                    if (conflicts.length > 0) {
                        conflictsList.innerHTML = conflicts.map(c => `<li>${c}</li>`).join('');
                        warningArea.style.display = 'block';
                    } else {
                        warningArea.style.display = 'none';
                    }
                })
                .catch(e => console.error('Error checking conflicts:', e));

            // Also check for suggestions if there are conflicts
            if (teacherId && classId && day && start && end && semesterId) {
                checkForSuggestions(semesterId, teacherId, classId, roomId > 0 ? roomId : null, day, start, end);
            }
        }

        // Real-time conflict detection and suggestions
        document.getElementById('teacherId').addEventListener('change', checkConflicts);
        document.getElementById('day').addEventListener('change', checkConflicts);
        document.getElementById('startTime').addEventListener('change', checkConflicts);
        document.getElementById('endTime').addEventListener('change', checkConflicts);
        document.getElementById('roomId').addEventListener('change', checkConflicts);

        async function checkForSuggestions(semesterId, teacherId, classBatchId, roomId, day, startTime, endTime) {
            if (!semesterId || !teacherId || !classBatchId || !day || !startTime || !endTime) {
                hideSuggestions();
                return;
            }

            try {
                const roomParam = roomId ? `&roomId=${roomId}` : '';
                const response = await fetch(`?handler=Suggestions&semesterId=${semesterId}&teacherId=${teacherId}&classBatchId=${classBatchId}${roomParam}&day=${encodeURIComponent(day)}&startTime=${startTime}&endTime=${endTime}`);
                const data = await response.json();

                if (data.success && data.suggestions && data.suggestions.length > 0) {
                    showSuggestions(data.suggestions);
                } else {
                    showValidSlot();
                }
            } catch (error) {
                console.error('Error checking suggestions:', error);
                hideSuggestions();
            }
        }

        function showSuggestions(suggestions) {
            const container = document.getElementById('suggestionsContainer');
            const list = document.getElementById('suggestionsList');
            const status = document.getElementById('conflictStatus');

            // Show conflict warning
            status.classList.remove('hidden');
            status.className = 'mb-4 p-3 rounded-lg text-sm flex items-center gap-2 bg-error-container text-on-error-container';
            status.innerHTML = '<span class="material-symbols-outlined">warning</span><span>⚠️ Conflict detected! Try these available times:</span>';

            // Populate suggestions
            list.innerHTML = suggestions.map(s => `
                <button type="button" onclick="useSuggestion('${s.day}', '${s.startTime}', '${s.endTime}')" 
                    class="w-full p-3 text-left rounded-lg bg-info/10 hover:bg-info/20 border border-info/30 transition-colors">
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="font-semibold text-sm text-on-surface">${s.day} ${s.startTime}–${s.endTime}</div>
                            <div class="text-xs text-on-surface-variant">${s.reason}</div>
                        </div>
                        <span class="material-symbols-outlined text-success">check_circle</span>
                    </div>
                </button>
            `).join('');

            container.classList.remove('hidden');
        }

        function showValidSlot() {
            const container = document.getElementById('suggestionsContainer');
            const status = document.getElementById('conflictStatus');

            status.classList.remove('hidden');
            status.className = 'mb-4 p-3 rounded-lg text-sm flex items-center gap-2 bg-success-container text-on-success-container';
            status.innerHTML = '<span class="material-symbols-outlined">check_circle</span><span>✓ No conflicts - slot is available!</span>';

            container.classList.add('hidden');
        }

        function hideSuggestions() {
            document.getElementById('suggestionsContainer').classList.add('hidden');
            document.getElementById('conflictStatus').classList.add('hidden');
        }

        function useSuggestion(day, startTime, endTime) {
            document.getElementById('day').value = day;
            document.getElementById('startTime').value = startTime;
            document.getElementById('endTime').value = endTime;
            checkConflicts();
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateSlotTypeVisibility();
        });
    </script>
}
