@page
@model Plannify.Pages.Admin.Timetable.ByRoomModel
@{
    ViewData["Title"] = "Timetable by Room";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-lg-8">
            <h2>Timetable by Room</h2>
        </div>
    </div>

    <!-- Top Controls -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="row g-3">
                <div class="col-md-4">
                    <label for="roomSelect" class="form-label">Select Room</label>
                    <select class="form-select" id="roomSelect" onchange="changeRoom()">
                        <option value="">-- Select Room --</option>
                        @foreach (var room in Model.Rooms)
                        {
                            <option value="@room.Value" @(room.Value == Model.CurrentRoom?.Id.ToString() ? "selected" : "")>@room.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="semesterSelect" class="form-label">Select Semester</label>
                    <select class="form-select" id="semesterSelect" onchange="changeSemester()">
                        <option value="">-- Select Semester --</option>
                        @foreach (var sem in Model.Semesters)
                        {
                            <option value="@sem.Value" @(sem.Value == Model.CurrentSemester?.Id.ToString() ? "selected" : "")>@sem.Text</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="d-grid gap-2 d-lg-flex justify-content-lg-end" style="height: 100%; align-items: flex-end;">
                <form method="post" asp-page-handler="PrintPdf" style="display: inline;">
                    <input type="hidden" name="roomId" value="@Model.CurrentRoom?.Id">
                    <input type="hidden" name="semesterId" value="@Model.CurrentSemester?.Id">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-print"></i> Print PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Left: Grid -->
        <div class="col-lg-8">
            @if (Model.CurrentRoom != null && Model.CurrentSemester != null && Model.TimeRanges.Count > 0)
            {
                <div class="card">
                    <div class="card-body p-0" style="overflow-x: auto;">
                        <table class="table table-bordered table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="min-width: 100px;">Time</th>
                                    @foreach (var day in Model.Days)
                                    {
                                        <th class="text-center" style="min-width: 120px;">@day.Substring(0, 3)</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var timeRange in Model.TimeRanges)
                                {
                                    <tr>
                                        <td class="text-center text-nowrap fw-bold">
                                            <small>@timeRange</small>
                                        </td>
                                        @foreach (var day in Model.Days)
                                        {
                                            var slot = Model.Grid[day][timeRange];
                                            string bgClass = "bg-light";
                                            
                                            if (slot != null)
                                            {
                                                bgClass = slot.SlotType switch
                                                {
                                                    "Theory" => "bg-white",
                                                    "Lab" => "tg-lab",
                                                    "GAP" => "tg-gap",
                                                    "Elective" => "bg-light-purple",
                                                    _ => "bg-light"
                                                };
                                            }

                                            <td class="@bgClass text-center align-middle" style="min-height: 60px;">
                                                @if (slot != null)
                                                {
                                                    <div class="small">
                                                        <strong>@slot.Subject?.Name</strong><br>
                                                        <span class="text-muted">@slot.ClassBatch?.BatchName</span><br>
                                                        <span class="badge bg-info">@slot.Teacher?.Initials</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Free</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else if (Model.CurrentRoom != null && Model.CurrentSemester != null)
            {
                <div class="alert alert-info">
                    No slots scheduled for this room in the selected semester.
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    Select a room and semester to view the timetable.
                </div>
            }
        </div>

        <!-- Right: Utilization Panel -->
        @if (Model.CurrentRoom != null)
        {
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <h6 class="mb-0">Room Utilization</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <div class="d-flex justify-content-between mb-2">
                                <span><strong>Utilization Rate</strong></span>
                                <span class="badge bg-primary">@Model.TotalOccupiedPeriods/@Model.TotalAvailablePeriods</span>
                            </div>
                            @{
                                string utilizationClass = Model.UtilizationPercentage < 50 ? "bg-warning" : 
                                                         Model.UtilizationPercentage < 75 ? "bg-info" : "bg-success";
                            }
                            <div class="progress" role="progressbar">
                                <div class="progress-bar @utilizationClass" style="width: @Math.Min(Model.UtilizationPercentage, 100)%"></div>
                            </div>
                            <small class="text-muted d-block mt-2">@Model.UtilizationPercentage.ToString("F1")% utilized</small>
                        </div>

                        <hr>

                        <div class="mb-3">
                            <h6 class="mb-3">Daily Utilization</h6>
                            @foreach (var day in Model.Days)
                            {
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small">@day.Substring(0, 3)</span>
                                        <span class="badge bg-light text-dark">@Model.PeriodsPerDay[day] periods</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <hr>

                        <div>
                            <h6 class="mb-2">Peak Usage</h6>
                            <div class="alert alert-info mb-0">
                                <strong>@Model.PeakUsageDay</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">Room Info</h6>
                    </div>
                    <div class="card-body small">
                        <p class="mb-2">
                            <strong>Room Number:</strong> @Model.CurrentRoom.RoomNumber
                        </p>
                        <p class="mb-2">
                            <strong>Building:</strong> @Model.CurrentRoom.BuildingName
                        </p>
                        <p class="mb-2">
                            <strong>Type:</strong> @Model.CurrentRoom.RoomType
                        </p>
                        <p class="mb-0">
                            <strong>Capacity:</strong> @Model.CurrentRoom.Capacity students
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function changeRoom() {
            const roomId = document.getElementById('roomSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (roomId && semesterId) {
                window.location = `?roomId=${roomId}&semesterId=${semesterId}`;
            }
        }

        function changeSemester() {
            const roomId = document.getElementById('roomSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (roomId && semesterId) {
                window.location = `?roomId=${roomId}&semesterId=${semesterId}`;
            }
        }
    </script>
}
