@page
@model Plannify.Pages.Admin.Timetable.ConflictsModel
@{
    ViewData["Title"] = "Conflict Report";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    <!-- Top Section -->
    <div class="mb-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label for="semesterSelect" class="block text-xs font-bold text-on-surface-variant mb-2">Semester</label>
                <form method="post" asp-page-handler="Scan" class="flex gap-2">
                    <select class="flex-1 px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="semesterSelect" name="scanSemesterId" asp-items="Model.Semesters">
                        <option value="">-- Select Semester --</option>
                    </select>
                    <button type="submit" class="bg-primary hover:bg-primary-container text-on-primary px-6 py-3 rounded-xl font-bold shadow-lg shadow-primary/20 transition-all">
                        <span class="material-symbols-outlined inline -mt-1">search</span>
                        Run Scan
                    </button>
                </form>
            </div>
        </div>
    </div>

    @if (Model.LastScanTime.HasValue)
    {
        <div class="bg-info/10 border border-info/30 rounded-lg p-3 mb-4">
            <small class="text-xs text-info">Last scanned: <strong>@Model.LastScanTime.Value.ToString("HH:mm:ss")</strong></small>
        </div>
    }

    <!-- Results -->
    @if (Model.ScanRan)
    {
        @if (Model.AllConflicts.Count == 0)
        {
            <div class="bg-green-50 border border-green-200 rounded-2xl p-6 text-center">
                <span class="material-symbols-outlined text-4xl text-green-600 block mb-2">check_circle</span>
                <p class="text-on-surface font-bold">No conflicts found for this semester. Timetable looks clean!</p>
            </div>
        }
        else
        {
            <!-- Summary Bar -->
            <div class="bg-warning/10 border border-warning/30 rounded-2xl p-4 mb-6">
                <p class="text-sm text-on-surface font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-base">warning</span>
                    Found <span class="text-warning">@Model.AllConflicts.Count</span> conflicts — 
                    <span class="px-3 py-1 bg-surface-container-low rounded-full text-xs">Teacher: @Model.TeacherConflicts.Count</span>
                    <span class="px-3 py-1 bg-surface-container-low rounded-full text-xs">Room: @Model.RoomConflicts.Count</span>
                    <span class="px-3 py-1 bg-surface-container-low rounded-full text-xs">Class: @Model.ClassConflicts.Count</span>
                </p>
            </div>
            <!-- Conflict Sections -->
            <div class="space-y-4">
                <!-- Teacher Double-Booking -->
                @if (Model.TeacherConflicts.Count > 0)
                {
                    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm">
                        <div class="px-6 py-4 bg-surface-container-low/50 cursor-pointer hover:bg-surface-container-low/70 transition-colors">
                            <h6 class="text-sm font-bold text-on-surface flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">person</span>
                                Teacher Double-Booking (<span class="text-warning">@Model.TeacherConflicts.Count</span>)
                            </h6>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="bg-surface-container-low/30 border-b border-outline-variant/20">
                                    <tr>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Teacher</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Day</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Time</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Slot 1</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Slot 2</th>
                                        <th class="text-center px-6 py-3 font-bold text-on-surface-variant text-xs">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var conflict in Model.TeacherConflicts)
                                    {
                                        <tr class="border-b border-outline-variant/20 hover:bg-surface-container-low/20 transition-colors">
                                            <td class="px-6 py-3 font-bold text-on-surface">@conflict.AffectedEntity</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.Day</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.StartTime.ToString("HH:mm") – @conflict.EndTime.ToString("HH:mm")</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot1Description</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot2Description</td>
                                            <td class="px-6 py-3 text-center">
                                                <a href="/Admin/Timetable/Create?slotId=@conflict.Slot1Id" class="px-3 py-1 bg-primary/10 text-primary hover:bg-primary hover:text-on-primary text-xs font-bold rounded transition-all inline-flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">edit</span>
                                                    Fix
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Room Double-Booking -->
                @if (Model.RoomConflicts.Count > 0)
                {
                    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm">
                        <div class="px-6 py-4 bg-surface-container-low/50 cursor-pointer hover:bg-surface-container-low/70 transition-colors">
                            <h6 class="text-sm font-bold text-on-surface flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">door_sliding</span>
                                Room Double-Booking (<span class="text-warning">@Model.RoomConflicts.Count</span>)
                            </h6>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="bg-surface-container-low/30 border-b border-outline-variant/20">
                                    <tr>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Room</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Day</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Time</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Class 1 + Subject</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Class 2 + Subject</th>
                                        <th class="text-center px-6 py-3 font-bold text-on-surface-variant text-xs">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var conflict in Model.RoomConflicts)
                                    {
                                        <tr class="border-b border-outline-variant/20 hover:bg-surface-container-low/20 transition-colors">
                                            <td class="px-6 py-3 font-bold text-on-surface">@conflict.AffectedEntity</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.Day</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.StartTime.ToString("HH:mm") – @conflict.EndTime.ToString("HH:mm")</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot1Description</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot2Description</td>
                                            <td class="px-6 py-3 text-center">
                                                <a href="/Admin/Timetable/Create?slotId=@conflict.Slot1Id" class="px-3 py-1 bg-primary/10 text-primary hover:bg-primary hover:text-on-primary text-xs font-bold rounded transition-all inline-flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">edit</span>
                                                    Fix
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Class Overlap -->
                @if (Model.ClassConflicts.Count > 0)
                {
                    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm">
                        <div class="px-6 py-4 bg-surface-container-low/50 cursor-pointer hover:bg-surface-container-low/70 transition-colors">
                            <h6 class="text-sm font-bold text-on-surface flex items-center gap-2">
                                <span class="material-symbols-outlined text-base">school</span>
                                Class Overlap (<span class="text-warning">@Model.ClassConflicts.Count</span>)
                            </h6>
                        </div>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead class="bg-surface-container-low/30 border-b border-outline-variant/20">
                                    <tr>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Class</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Day</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Time</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Subject 1 + Teacher</th>
                                        <th class="text-left px-6 py-3 font-bold text-on-surface-variant text-xs">Subject 2 + Teacher</th>
                                        <th class="text-center px-6 py-3 font-bold text-on-surface-variant text-xs">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var conflict in Model.ClassConflicts)
                                    {
                                        <tr class="border-b border-outline-variant/20 hover:bg-surface-container-low/20 transition-colors">
                                            <td class="px-6 py-3 font-bold text-on-surface">@conflict.AffectedEntity</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.Day</td>
                                            <td class="px-6 py-3 text-on-surface-variant">@conflict.StartTime.ToString("HH:mm") – @conflict.EndTime.ToString("HH:mm")</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot1Description</td>
                                            <td class="px-6 py-3 text-on-surface-variant text-xs">@conflict.Slot2Description</td>
                                            <td class="px-6 py-3 text-center">
                                                <a href="/Admin/Timetable/Create?slotId=@conflict.Slot1Id" class="px-3 py-1 bg-primary/10 text-primary hover:bg-primary hover:text-on-primary text-xs font-bold rounded transition-all inline-flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">edit</span>
                                                    Fix
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        <div class="bg-info/10 border border-info/30 rounded-2xl p-6 text-center">
            <span class="material-symbols-outlined text-2xl text-info block mb-2">info</span>
            <p class="text-sm text-on-surface">Select a semester and run a scan to detect conflicts.</p>
        </div>
    }
</div>
