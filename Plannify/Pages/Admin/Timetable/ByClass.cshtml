@page
@model Plannify.Pages.Admin.Timetable.ByClassModel
@{
    ViewData["Title"] = "Timetable by Class";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    <!-- Top Controls -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
        <div class="lg:col-span-2">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label for="classSelect" class="block text-xs font-bold text-on-surface-variant mb-2">Select Class</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="classSelect" onchange="changeClass()">
                        <option value="">-- Select Class --</option>
                        @foreach (var cls in Model.ClassBatches)
                        {
                            @if (cls.Value == Model.CurrentClass?.Id.ToString())
                            {
                                <option value="@cls.Value" selected>@cls.Text</option>
                            }
                            else
                            {
                                <option value="@cls.Value">@cls.Text</option>
                            }
                        }
                    </select>
                </div>
                <div>
                    <label for="semesterSelect" class="block text-xs font-bold text-on-surface-variant mb-2">Select Semester</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30" id="semesterSelect" onchange="changeSemester()">
                        <option value="">-- Select Semester --</option>
                        @foreach (var sem in Model.Semesters)
                        {
                            @if (sem.Value == Model.CurrentSemester?.Id.ToString())
                            {
                                <option value="@sem.Value" selected>@sem.Text</option>
                            }
                            else
                            {
                                <option value="@sem.Value">@sem.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
        <div class="lg:col-span-1 flex items-end">
            <form method="post" asp-page-handler="ExportPdf" class="w-full">
                <input type="hidden" name="classId" value="@Model.CurrentClass?.Id">
                <input type="hidden" name="semesterId" value="@Model.CurrentSemester?.Id">
                <button type="submit" class="w-full bg-primary hover:bg-primary-container text-on-primary px-4 py-3 rounded-xl font-bold shadow-lg shadow-primary/20 transition-all @(Model.CurrentClass == null ? "opacity-40 cursor-not-allowed" : "")" @(Model.CurrentClass == null ? "disabled" : "")>
                    <span class="material-symbols-outlined inline mr-2 -mt-1">print</span>
                    Print PDF
                </button>
            </form>
        </div>
    </div>

    @if (Model.CurrentClass != null && Model.CurrentSemester != null && Model.TimeRanges.Count > 0)
    {
        <!-- Timetable Grid -->
        <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/20 overflow-hidden shadow-sm mb-6">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-surface-container-low/50 border-b border-outline-variant/20">
                        <tr>
                            <th class="text-center px-4 py-4 font-bold text-on-surface min-w-[100px]" style="width: 100px;">Time</th>
                            @foreach (var day in Model.Days)
                            {
                                <th class="text-center px-4 py-4 font-bold text-on-surface min-w-[120px]" style="width: 120px;">@day.Substring(0, 3)</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var timeRange in Model.TimeRanges)
                        {
                            <tr class="border-b border-outline-variant/20 hover:bg-surface-container-low/30 transition-colors">
                                <td class="text-center px-4 py-4 font-bold text-on-surface text-xs text-nowrap">
                                    @timeRange
                                </td>
                                @foreach (var day in Model.Days)
                                {
                                    var slot = Model.Grid[day][timeRange];
                                    string bgClass = "";
                                    
                                    if (slot != null && slot.SlotType == "Theory")
                                    {
                                        bgClass = "bg-white";
                                    }
                                    else if (slot != null && slot.SlotType == "Lab")
                                    {
                                        bgClass = "bg-blue-50";
                                    }
                                    else if (slot != null && slot.SlotType == "GAP")
                                    {
                                        bgClass = "bg-gray-100";
                                    }
                                    else
                                    {
                                        bgClass = "bg-surface-container-low/20";
                                    }

                                    <td class="text-center px-4 py-4 align-middle @bgClass" style="min-height: 60px;">
                                        @if (slot != null && slot.SlotType == "GAP")
                                        {
                                            <span class="text-on-surface-variant italic text-xs">— GAP —</span>
                                        }
                                        else if (slot != null)
                                        {
                                            <div class="text-xs space-y-1">
                                                <div class="font-bold text-on-surface">@slot.Subject?.Code</div>
                                                @if (slot.SlotType == "Lab")
                                                {
                                                    <span class="inline-block px-2 py-1 bg-blue-200 text-blue-800 text-xs font-bold rounded">LAB</span>
                                                }
                                                <div class="text-on-surface-variant">@slot.Teacher?.Initials</div>
                                                <div class="text-on-surface-variant">@slot.Room?.RoomNumber</div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-on-surface-variant text-xs">Free</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Summary Row -->
        <div class="alert alert-light mt-3 mb-4 border">
            <strong>Total Teaching Slots: @Model.TotalTeachingSlots | Total GAP Slots: @Model.TotalGapSlots | Total Free Slots: @Model.TotalFreeSlots</strong>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Select a class and semester to view the timetable.
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeClass() {
            const classId = document.getElementById('classSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (classId && semesterId) {
                window.location = `?classId=${classId}&semesterId=${semesterId}`;
            }
        }

        function changeSemester() {
            const classId = document.getElementById('classSelect').value;
            const semesterId = document.getElementById('semesterSelect').value;
            if (classId && semesterId) {
                window.location = `?classId=${classId}&semesterId=${semesterId}`;
            }
        }
    </script>
}
