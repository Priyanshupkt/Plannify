@page
@model TeachersModel
@{
    ViewData["Title"] = "Manage Teachers";
}

<h1>Manage Teachers</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Add New Teacher</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="Add">
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="NewTeacher_Name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="NewTeacher_Name" asp-for="NewTeacher.Name" required />
                        <span class="text-danger" asp-validation-for="NewTeacher.Name"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="NewTeacher_Initials" class="form-label">Initials</label>
                        <input type="text" class="form-control" id="NewTeacher_Initials" asp-for="NewTeacher.Initials" required />
                        <span class="text-danger" asp-validation-for="NewTeacher.Initials"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label d-block">&nbsp;</label>
                        <button type="submit" class="btn btn-success">Add Teacher</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Teachers.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Initials</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Teachers.Count; i++)
                {
                    var teacher = Model.Teachers[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@teacher.Name</td>
                        <td>@teacher.Initials</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@teacher.Id" style="display: inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        No teachers found.
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
