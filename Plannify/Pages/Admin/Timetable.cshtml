@page
@model TimetableModel
@{
    ViewData["Title"] = "Create Timetable Slot";
}

<h1>Create Timetable Slot</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Add New Slot</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="Add">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="NewSlot_Day" class="form-label">Day</label>
                    <select class="form-select" id="NewSlot_Day" asp-for="NewSlot.Day" asp-items="Model.DayOptions" required>
                        <option value="">-- Select Day --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="NewSlot.Day"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label for="NewSlot_StartTime" class="form-label">Start Time</label>
                    <input type="time" class="form-control" id="NewSlot_StartTime" asp-for="NewSlot.StartTime" required />
                    <span class="text-danger" asp-validation-for="NewSlot.StartTime"></span>
                </div>
                <div class="col-md-3 mb-3">
                    <label for="NewSlot_EndTime" class="form-label">End Time</label>
                    <input type="time" class="form-control" id="NewSlot_EndTime" asp-for="NewSlot.EndTime" required />
                    <span class="text-danger" asp-validation-for="NewSlot.EndTime"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label for="NewSlot_TeacherId" class="form-label">Teacher</label>
                    <select class="form-select" id="NewSlot_TeacherId" asp-for="NewSlot.TeacherId" asp-items="Model.TeacherList" required>
                        <option value="">-- Select Teacher --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="NewSlot.TeacherId"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="NewSlot_SubjectId" class="form-label">Subject</label>
                    <select class="form-select" id="NewSlot_SubjectId" asp-for="NewSlot.SubjectId" asp-items="Model.SubjectList" required>
                        <option value="">-- Select Subject --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="NewSlot.SubjectId"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label for="NewSlot_ClassId" class="form-label">Class</label>
                    <select class="form-select" id="NewSlot_ClassId" asp-for="NewSlot.ClassId" asp-items="Model.ClassList" required>
                        <option value="">-- Select Class --</option>
                    </select>
                    <span class="text-danger" asp-validation-for="NewSlot.ClassId"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 mb-3">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="NewSlot_IsGap" asp-for="NewSlot.IsGap" />
                        <label class="form-check-label" for="NewSlot_IsGap">Mark as GAP</label>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-success">Save Slot</button>
        </form>
    </div>
</div>

<h2>All Timetable Slots</h2>

@if (Model.Slots.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Day</th>
                    <th>Time</th>
                    <th>Teacher</th>
                    <th>Subject</th>
                    <th>Class</th>
                    <th>GAP</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Slots.Count; i++)
                {
                    var slot = Model.Slots[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@slot.Day</td>
                        <td>@slot.StartTime – @slot.EndTime</td>
                        <td>@slot.Teacher?.Name</td>
                        <td>@slot.Subject?.Name (@slot.Subject?.Code)</td>
                        <td>@slot.Class?.BatchName (@slot.Class?.RoomNo)</td>
                        <td>@(slot.IsGap ? "Yes" : "-")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@slot.Id" style="display: inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        No slots created yet.
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
