@page "/Admin/Rooms"
@model Plannify.Pages.Admin.Rooms.IndexModel
@{
    ViewData["Title"] = "Rooms";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Add Room Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Room</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-4 gap-4">
            <div>
                <label for="NewRoom_Number" class="block text-sm font-medium text-on-surface mb-2">Room Number</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewRoom_Number" asp-for="NewRoom.RoomNumber" placeholder="e.g., A101" required>
                <span asp-validation-for="NewRoom.RoomNumber" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewRoom_Building" class="block text-sm font-medium text-on-surface mb-2">Building Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewRoom_Building" asp-for="NewRoom.BuildingName" placeholder="e.g., Building A" required>
                <span asp-validation-for="NewRoom.BuildingName" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewRoom_Capacity" class="block text-sm font-medium text-on-surface mb-2">Capacity</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewRoom_Capacity" asp-for="NewRoom.Capacity" min="1" required>
                <span asp-validation-for="NewRoom.Capacity" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewRoom_Type" class="block text-sm font-medium text-on-surface mb-2">Room Type</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewRoom_Type" asp-for="NewRoom.RoomType" required>
                    <option value="">-- Select Type --</option>
                    <option value="Lecture">Lecture Hall</option>
                    <option value="Lab">Laboratory</option>
                    <option value="Seminar">Seminar Hall</option>
                    <option value="Hall">Auditorium</option>
                </select>
                <span asp-validation-for="NewRoom.RoomType" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Room</button>
        </div>
    </form>
</div>

<!-- Rooms Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">meeting_room</span>
        <h3 class="text-lg font-semibold text-on-surface">Rooms List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.Rooms.Count record(s)</div>
    </div>
    
    @if (Model.Rooms.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Room Number</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Building</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Capacity</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Type</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Slots This Week</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var room in Model.Rooms)
                        {
                            var typeBg = room.RoomType switch
                            {
                                "Lecture" => "bg-secondary-fixed text-on-secondary-fixed",
                                "Lab" => "bg-error-fixed text-on-error-fixed",
                                "Seminar" => "bg-tertiary-fixed text-on-tertiary-fixed",
                                "Hall" => "bg-primary-fixed text-on-primary-fixed",
                                _ => "bg-on-surface-variant/10 text-on-surface-variant"
                            };

                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@room.RoomNumber</td>
                                <td class="px-4 py-5 text-sm text-on-surface">@room.BuildingName</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold rounded-full">@room.Capacity</span></td>
                                <td class="px-4 py-5"><span class="px-3 py-1 @typeBg font-bold text-xs rounded-full">@room.RoomType</span></td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-secondary-fixed text-on-secondary-fixed font-bold rounded-full">@(Model.SlotCounts.ContainsKey(room.Id) ? Model.SlotCounts[room.Id] : 0)</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button type="button" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" 
                                                onclick="showEditModal(@room.Id, '@room.RoomNumber', '@room.BuildingName', @room.Capacity, '@room.RoomType')">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@room.Id', '@room.RoomNumber')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No rooms found. Create one to get started.</p>
        </div>
    }
</div>

<!-- Edit Modal -->
<div id="editRoomModal" class="fixed inset-0 z-[100] hidden backdrop-blur-sm bg-black/40 flex items-center justify-center">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl max-w-sm w-full mx-4">
        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold text-on-surface">Edit Room</h3>
            <button type="button" class="p-2 hover:bg-on-surface/5 rounded-lg transition-colors" onclick="hideEditModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form method="post" asp-page-handler="Update">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <input type="hidden" id="editRoomId" name="id">
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Room Number</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editRoomNumber" name="roomNumber" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Building Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editRoomBuilding" name="buildingName" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Capacity</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editRoomCapacity" name="capacity" min="1" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Room Type</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editRoomType" name="roomType" required>
                        <option value="Lecture">Lecture Hall</option>
                        <option value="Lab">Laboratory</option>
                        <option value="Seminar">Seminar Hall</option>
                        <option value="Hall">Auditorium</option>
                    </select>
                </div>
            </div>
            
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant/10">
                <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="hideEditModal()">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showEditModal(id, roomNumber, buildingName, capacity, roomType) {
            document.getElementById('editRoomId').value = id;
            document.getElementById('editRoomNumber').value = roomNumber;
            document.getElementById('editRoomBuilding').value = buildingName;
            document.getElementById('editRoomCapacity').value = capacity;
            document.getElementById('editRoomType').value = roomType;
            document.getElementById('editRoomModal').classList.remove('hidden');
        }

        function hideEditModal() {
            document.getElementById('editRoomModal').classList.add('hidden');
        }

        function showDeleteModal(id, roomNumber) {
            const confirmed = confirm(`Delete room "${roomNumber}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Close modal when clicking outside
        document.getElementById('editRoomModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideEditModal();
            }
        });
    </script>
}
