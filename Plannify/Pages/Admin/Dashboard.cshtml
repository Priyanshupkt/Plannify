@page "/Admin/Dashboard"
@model Plannify.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Section"] = "Overview";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Stat Cards Grid (2 rows of 4) -->
<div class="grid grid-cols-4 gap-4 mb-8">
    <!-- Teachers -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-primary">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Total Teachers</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.TotalTeachers</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-primary/30">group</span>
        </div>
    </div>

    <!-- Classes -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-success">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Total Classes</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.TotalClasses</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-success/30">school</span>
        </div>
    </div>

    <!-- Subjects -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-info">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Total Subjects</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.TotalSubjects</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-info/30">library_books</span>
        </div>
    </div>

    <!-- Rooms -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-tertiary">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Active Rooms</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.ActiveRooms</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-tertiary/30">meeting_room</span>
        </div>
    </div>

    <!-- Slots -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-primary-fixed">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Total Slots</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.TotalSlots</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-primary-fixed/30">grid_on</span>
        </div>
    </div>

    <!-- Conflicts -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 @(Model.ConflictCount > 0 ? "border-error" : "border-success")">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Conflicts</p>
                <h3 class="text-3xl font-bold @(Model.ConflictCount > 0 ? "text-error" : "text-success")">@Model.ConflictCount</h3>
            </div>
            <span class="material-symbols-outlined text-4xl @(Model.ConflictCount > 0 ? "text-error/30" : "text-success/30")">@(Model.ConflictCount > 0 ? "warning" : "check_circle")</span>
        </div>
    </div>

    <!-- Substitutions -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 border-warning">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Pending Substitutions</p>
                <h3 class="text-3xl font-bold text-on-surface">@Model.PendingSubstitutions</h3>
            </div>
            <span class="material-symbols-outlined text-4xl text-warning/30">people_alt</span>
        </div>
    </div>

    <!-- Overloaded Teachers -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 border-l-4 @(Model.OverloadedTeachersCount > 0 ? "border-error" : "border-on-surface-variant/20")">
        <div class="flex items-start justify-between">
            <div>
                <p class="text-sm text-on-surface-variant mb-1">Overloaded Teachers</p>
                <h3 class="text-3xl font-bold @(Model.OverloadedTeachersCount > 0 ? "text-error" : "text-on-surface")">@Model.OverloadedTeachersCount</h3>
            </div>
            <span class="material-symbols-outlined text-4xl @(Model.OverloadedTeachersCount > 0 ? "text-error/30" : "text-on-surface-variant/20")">trending_up</span>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="grid grid-cols-3 gap-4">
    <a href="/Admin/Timetable/Create" class="bg-primary text-on-primary rounded-2xl p-6 hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl">add_circle</span>
            <div>
                <h4 class="font-semibold">Create Slot</h4>
                <p class="text-sm opacity-90">Add new timetable entry</p>
            </div>
        </div>
    </a>

    <a href="/Admin/Timetable/Conflicts" class="@(Model.ConflictCount > 0 ? "bg-error text-on-error" : "bg-success text-on-success") rounded-2xl p-6 hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl">@(Model.ConflictCount > 0 ? "warning" : "check_circle")</span>
            <div>
                <h4 class="font-semibold">View Conflicts</h4>
                <p class="text-sm opacity-90">@(Model.ConflictCount > 0 ? $"{Model.ConflictCount} conflicts found" : "No conflicts")</p>
            </div>
        </div>
    </a>

    <a href="/Admin/Substitutions" class="bg-tertiary text-on-tertiary rounded-2xl p-6 hover:shadow-lg transition-shadow">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-3xl">assignment</span>
            <div>
                <h4 class="font-semibold">Substitutions</h4>
                <p class="text-sm opacity-90">@(Model.PendingSubstitutions > 0 ? $"{Model.PendingSubstitutions} pending" : "Manage teacher substitutions")</p>
            </div>
        </div>
    </a>
</div>


<!-- Analytics & Activity Section -->
<div class="grid grid-cols-2 gap-6 mt-8">
    <!-- Recent Activity -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
        <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
            <span class="material-symbols-outlined text-primary">history</span>
            <h3 class="text-lg font-semibold text-on-surface">Recent Activity</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Time</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Action</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Entity</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentActivity != null && Model.RecentActivity.Any())
                    {
                        @foreach (var activity in Model.RecentActivity)
                        {
                            <tr class="border-t border-outline-variant/10 hover:bg-surface-container-low/30">
                                <td class="px-6 py-3 text-xs text-on-surface-variant">@activity.PerformedAt.ToString("g")</td>
                                <td class="px-6 py-3"><span class="px-2 py-1 bg-primary-fixed text-on-primary-fixed text-xs font-bold rounded-full">@activity.Action</span></td>
                                <td class="px-6 py-3 text-sm text-on-surface">@activity.EntityName</td>
                                <td class="px-6 py-3 text-sm text-on-surface">@activity.PerformedBy</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-8 text-center text-on-surface-variant">No recent activity</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Overloaded Teachers -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
        <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
            <span class="material-symbols-outlined text-error">warning</span>
            <h3 class="text-lg font-semibold text-on-surface">Overloaded Teachers</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Teacher</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Hours</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OverloadedTeachers != null && Model.OverloadedTeachers.Any())
                    {
                        @foreach (var teacher in Model.OverloadedTeachers.Take(8))
                        {
                            <tr class="border-t border-outline-variant/10 hover:bg-surface-container-low/30">
                                <td class="px-6 py-3 text-sm text-on-surface">@teacher.TeacherName</td>
                                <td class="px-6 py-3"><span class="px-2 py-1 bg-error text-on-error text-xs font-bold rounded-full">@teacher.MaxHours</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="2" class="px-6 py-8 text-center text-on-surface-variant">No overloaded teachers</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    @* Chart.js now installed globally if needed for future charts *@
    <script>
        // Auto-dismiss alerts after 4 seconds
        window.flashAlerts?.init();
    </script>
}
