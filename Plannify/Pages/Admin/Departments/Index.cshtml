@page "/Admin/Departments"
@model Plannify.Pages.Admin.Departments.IndexModel
@{
    ViewData["Title"] = "Departments";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Add Department Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Department</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-4 gap-4">
            <div>
                <label for="NewDept_Name" class="block text-sm font-medium text-on-surface mb-2">Department Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewDept_Name" asp-for="NewDepartment.Name" placeholder="e.g., Computer Science" required>
                <span asp-validation-for="NewDepartment.Name" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewDept_Code" class="block text-sm font-medium text-on-surface mb-2">Code</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewDept_Code" asp-for="NewDepartment.Code" placeholder="e.g., CS" required>
                <span asp-validation-for="NewDepartment.Code" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewDept_ShortName" class="block text-sm font-medium text-on-surface mb-2">Short Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewDept_ShortName" asp-for="NewDepartment.ShortName" placeholder="e.g., CSE">
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Department</button>
        </div>
    </form>
</div>

<!-- Departments Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">list</span>
        <h3 class="text-lg font-semibold text-on-surface">Departments List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.Departments.Count record(s)</div>
    </div>
    
    @if (Model.Departments.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Code</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Short Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Teachers</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var dept in Model.Departments)
                        {
                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@dept.Name</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed font-bold rounded-full">@dept.Code</span></td>
                                <td class="px-4 py-5 text-sm text-on-surface">@(dept.ShortName ?? "-")</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold rounded-full">@dept.TeacherCount teachers</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button type="button" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" 
                                                onclick="showEditModal(@dept.Id, '@dept.Name', '@dept.Code', '@(dept.ShortName ?? "")')">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@dept.Id', '@dept.Name')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No departments found. Create one to get started.</p>
        </div>
    }
</div>

<!-- Edit Modal -->
<div id="editDeptModal" class="fixed inset-0 z-[100] hidden backdrop-blur-sm bg-black/40 flex items-center justify-center">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl max-w-sm w-full mx-4">
        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold text-on-surface">Edit Department</h3>
            <button type="button" class="p-2 hover:bg-on-surface/5 rounded-lg transition-colors" onclick="hideEditModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form method="post" asp-page-handler="Update">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <input type="hidden" id="editDeptId" name="id">
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editDeptName" name="name" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Code</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editDeptCode" name="code" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Short Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editDeptShortName" name="shortName">
                </div>
            </div>
            
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant/10">
                <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="hideEditModal()">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showEditModal(id, name, code, shortName) {
            document.getElementById('editDeptId').value = id;
            document.getElementById('editDeptName').value = name;
            document.getElementById('editDeptCode').value = code;
            document.getElementById('editDeptShortName').value = shortName;
            document.getElementById('editDeptModal').classList.remove('hidden');
        }

        function hideEditModal() {
            document.getElementById('editDeptModal').classList.add('hidden');
        }

        function showDeleteModal(id, name) {
            const confirmed = confirm(`Delete department "${name}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Close modal when clicking outside
        document.getElementById('editDeptModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideEditModal();
            }
        });
    </script>
}

