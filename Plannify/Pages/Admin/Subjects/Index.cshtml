@page "/Admin/Subjects"
@model Plannify.Pages.Admin.Subjects.IndexModel
@{
    ViewData["Title"] = "Subjects";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Add Subject Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Subject</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label for="NewSubj_Name" class="block text-sm font-medium text-on-surface mb-2">Subject Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Name" asp-for="NewSubject.Name" placeholder="e.g., Data Structures" required>
                <span asp-validation-for="NewSubject.Name" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSubj_Code" class="block text-sm font-medium text-on-surface mb-2">Subject Code</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Code" asp-for="NewSubject.Code" placeholder="e.g., CS201" required>
                <span asp-validation-for="NewSubject.Code" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSubj_Credits" class="block text-sm font-medium text-on-surface mb-2">Credits</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Credits" asp-for="NewSubject.Credits" min="1" max="4" required>
                <span asp-validation-for="NewSubject.Credits" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSubj_Type" class="block text-sm font-medium text-on-surface mb-2">Subject Type</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Type" asp-for="NewSubject.SubjectType" required>
                    <option value="">-- Select Type --</option>
                    <option value="Theory">Theory</option>
                    <option value="Lab">Laboratory</option>
                    <option value="Elective">Elective</option>
                </select>
                <span asp-validation-for="NewSubject.SubjectType" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSubj_Dept" class="block text-sm font-medium text-on-surface mb-2">Department</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Dept" asp-for="NewSubject.DepartmentId" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))" required>
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="NewSubject.DepartmentId" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewSubj_Sem" class="block text-sm font-medium text-on-surface mb-2">Semester Number</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewSubj_Sem" asp-for="NewSubject.SemesterNumber" min="1" max="8" required>
                <span asp-validation-for="NewSubject.SemesterNumber" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Subject</button>
        </div>
    </form>
</div>

<!-- Filters -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-primary">filter_alt</span>
        <h3 class="text-lg font-semibold text-on-surface">Filters</h3>
    </div>
    <form method="get" class="grid grid-cols-3 gap-4">
        <div>
            <label for="departmentFilter" class="block text-sm font-medium text-on-surface mb-2">Department</label>
            <select id="departmentFilter" name="departmentId" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none">
                <option value="">-- All Departments --</option>
                @foreach (var dept in Model.Departments)
                {
                    <option value="@dept.Id" selected="@(Model.FilterDepartmentId == dept.Id)">@dept.Name</option>
                }
            </select>
        </div>
        <div>
            <label for="typeFilter" class="block text-sm font-medium text-on-surface mb-2">Subject Type</label>
            <select id="typeFilter" name="subjectType" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none">
                <option value="">-- All Types --</option>
                <option value="Theory" selected="@(Model.FilterSubjectType == "Theory")">Theory</option>
                <option value="Lab" selected="@(Model.FilterSubjectType == "Lab")">Laboratory</option>
                <option value="Elective" selected="@(Model.FilterSubjectType == "Elective")">Elective</option>
            </select>
        </div>
        <div class="flex items-end gap-3">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Filter</button>
            <a href="/Admin/Subjects/" class="px-6 py-3 bg-surface-container-low text-on-surface-variant font-medium rounded-xl hover:bg-surface-container-low/80 transition-colors">Reset</a>
        </div>
    </form>
</div>

<!-- Subjects Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">library_books</span>
        <h3 class="text-lg font-semibold text-on-surface">Subjects List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.Subjects.Count record(s)</div>
    </div>
    
    @if (Model.Subjects.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Code</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Type</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Department</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Semester</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Credits</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var subject in Model.Subjects)
                        {
                            var typeBg = subject.SubjectType switch
                            {
                                "Theory" => "bg-primary-fixed text-on-primary-fixed",
                                "Lab" => "bg-error-fixed text-on-error-fixed",
                                "Elective" => "bg-tertiary-fixed text-on-tertiary-fixed",
                                _ => "bg-on-surface-variant/10 text-on-surface-variant"
                            };
                            var deptName = Model.Departments.FirstOrDefault(d => d.Id == subject.DepartmentId)?.Name ?? "N/A";

                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-xs"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed font-bold rounded-full">@subject.Code</span></td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@subject.Name</td>
                                <td class="px-4 py-5"><span class="px-3 py-1 @typeBg font-bold text-xs rounded-full">@subject.SubjectType</span></td>
                                <td class="px-4 py-5 text-sm text-on-surface">@deptName</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-on-surface-variant/10 text-on-surface-variant font-bold rounded-full">Sem @subject.SemesterNumber</span></td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold rounded-full">@subject.Credits</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button type="button" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" 
                                                onclick="showEditModal(@subject.Id, '@subject.Name', '@subject.Code', @subject.Credits, '@subject.SubjectType', @subject.DepartmentId, @subject.SemesterNumber)">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@subject.Id', '@subject.Code')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No subjects found matching your filters.</p>
        </div>
    }
</div>

<!-- Edit Modal -->
<div id="editSubjModal" class="fixed inset-0 z-[100] hidden backdrop-blur-sm bg-black/40 flex items-center justify-center">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl max-w-sm w-full mx-4">
        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold text-on-surface">Edit Subject</h3>
            <button type="button" class="p-2 hover:bg-on-surface/5 rounded-lg transition-colors" onclick="hideEditModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form method="post" asp-page-handler="Update">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <input type="hidden" id="editSubjId" name="id">
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjName" name="name" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Code</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjCode" name="code" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Credits</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjCredits" name="credits" min="1" max="4" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Subject Type</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjType" name="subjectType" required>
                        <option value="Theory">Theory</option>
                        <option value="Lab">Laboratory</option>
                        <option value="Elective">Elective</option>
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Department</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjDept" name="departmentId" required>
                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Semester Number</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editSubjSem" name="semesterNumber" min="1" max="8" required>
                </div>
            </div>
            
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant/10">
                <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="hideEditModal()">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showEditModal(id, name, code, credits, subjectType, departmentId, semesterNumber) {
            document.getElementById('editSubjId').value = id;
            document.getElementById('editSubjName').value = name;
            document.getElementById('editSubjCode').value = code;
            document.getElementById('editSubjCredits').value = credits;
            document.getElementById('editSubjType').value = subjectType;
            document.getElementById('editSubjDept').value = departmentId;
            document.getElementById('editSubjSem').value = semesterNumber;
            document.getElementById('editSubjModal').classList.remove('hidden');
        }

        function hideEditModal() {
            document.getElementById('editSubjModal').classList.add('hidden');
        }

        function showDeleteModal(id, subjectCode) {
            const confirmed = confirm(`Delete subject "${subjectCode}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Close modal when clicking outside
        document.getElementById('editSubjModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideEditModal();
            }
        });
    </script>
}
