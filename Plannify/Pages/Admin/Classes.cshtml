@page
@model ClassesModel
@{
    ViewData["Title"] = "Manage Classes";
}

<h1>Manage Classes</h1>

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">Add New Class</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-page-handler="Add">
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="NewClass_BatchName" class="form-label">Batch Name</label>
                        <input type="text" class="form-control" id="NewClass_BatchName" asp-for="NewClass.BatchName" required />
                        <span class="text-danger" asp-validation-for="NewClass.BatchName"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="NewClass_RoomNo" class="form-label">Room Number</label>
                        <input type="text" class="form-control" id="NewClass_RoomNo" asp-for="NewClass.RoomNo" required />
                        <span class="text-danger" asp-validation-for="NewClass.RoomNo"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label class="form-label d-block">&nbsp;</label>
                        <button type="submit" class="btn btn-success">Add Class</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Classes.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Batch Name</th>
                    <th>Room No</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Classes.Count; i++)
                {
                    var classItem = Model.Classes[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@classItem.BatchName</td>
                        <td>@classItem.RoomNo</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@classItem.Id" style="display: inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        No classes found.
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
