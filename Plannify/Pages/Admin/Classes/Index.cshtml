@page "/Admin/Classes"
@model Plannify.Pages.Admin.Classes.IndexModel
@{
    ViewData["Title"] = "Classes";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Add Class Form -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">add_circle</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Class Batch</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label for="NewClass_Name" class="block text-sm font-medium text-on-surface mb-2">Batch Name</label>
                <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Name" asp-for="NewClassBatch.BatchName" placeholder="e.g., CS-A 2023" required>
                <span asp-validation-for="NewClassBatch.BatchName" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewClass_Strength" class="block text-sm font-medium text-on-surface mb-2">Batch Strength (Students)</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Strength" asp-for="NewClassBatch.Strength" min="1" required>
                <span asp-validation-for="NewClassBatch.Strength" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewClass_Dept" class="block text-sm font-medium text-on-surface mb-2">Department</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Dept" asp-for="NewClassBatch.DepartmentId" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))" required>
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="NewClassBatch.DepartmentId" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewClass_Year" class="block text-sm font-medium text-on-surface mb-2">Academic Year</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Year" asp-for="NewClassBatch.AcademicYearId" asp-items="@(new SelectList(Model.AcademicYears, "Id", "YearLabel"))" required>
                    <option value="">-- Select Academic Year --</option>
                </select>
                <span asp-validation-for="NewClassBatch.AcademicYearId" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewClass_Sem" class="block text-sm font-medium text-on-surface mb-2">Semester</label>
                <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Sem" asp-for="NewClassBatch.Semester" min="1" max="8" required>
                <span asp-validation-for="NewClassBatch.Semester" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label for="NewClass_Room" class="block text-sm font-medium text-on-surface mb-2">Default Room (Optional)</label>
                <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="NewClass_Room" asp-for="NewClassBatch.RoomId" asp-items="@(new SelectList(Model.Rooms, "Id", "RoomNumber"))">
                    <option value="">-- None --</option>
                </select>
            </div>
        </div>
        <div class="flex justify-end mt-4">
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Class Batch</button>
        </div>
    </form>
</div>

<!-- Class Batches Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">class</span>
        <h3 class="text-lg font-semibold text-on-surface">Class Batches List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.ClassBatches.Count record(s)</div>
    </div>
    
    @if (Model.ClassBatches.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Batch Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Strength</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Department</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Semester</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Year</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Default Room</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Slots</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int index = 1;
                        foreach (var batch in Model.ClassBatches)
                        {
                            var deptName = Model.Departments.FirstOrDefault(d => d.Id == batch.DepartmentId)?.Name ?? "N/A";
                            var yearLabel = Model.AcademicYears.FirstOrDefault(ay => ay.Id == batch.AcademicYearId)?.YearLabel ?? "N/A";
                            var roomNumber = Model.Rooms.FirstOrDefault(r => r.Id == batch.RoomId)?.RoomNumber ?? "-";

                            <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                                <td class="px-8 py-5 text-sm text-on-surface">@(index++)</td>
                                <td class="px-8 py-5 text-sm font-medium text-on-surface">@batch.BatchName</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed font-bold rounded-full">@batch.Strength</span></td>
                                <td class="px-4 py-5 text-sm text-on-surface">@deptName</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-on-surface-variant/10 text-on-surface-variant font-bold rounded-full">Sem @batch.Semester</span></td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-tertiary-fixed text-on-tertiary-fixed font-bold rounded-full">@yearLabel</span></td>
                                <td class="px-4 py-5 text-sm text-on-surface">@roomNumber</td>
                                <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-secondary-fixed text-on-secondary-fixed font-bold rounded-full">@(Model.SlotCounts.ContainsKey(batch.Id) ? Model.SlotCounts[batch.Id] : 0)</span></td>
                                <td class="px-4 py-5">
                                    <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <a href="/Admin/Timetable/ByClass?classId=@batch.Id" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors">
                                            <span class="material-symbols-outlined text-lg">visibility</span>
                                        </a>
                                        <button type="button" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" 
                                                onclick="showEditModal(@batch.Id, '@batch.BatchName', @batch.Strength, @batch.DepartmentId, @batch.AcademicYearId, @batch.Semester, @(batch.RoomId ?? 0))">
                                            <span class="material-symbols-outlined text-lg">edit</span>
                                        </button>
                                        <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                                onclick="showDeleteModal('@batch.Id', '@batch.BatchName')">
                                            <span class="material-symbols-outlined text-lg">delete</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No class batches found. Create one to get started.</p>
        </div>
    }
</div>

<!-- Edit Modal -->
<div id="editClassModal" class="fixed inset-0 z-[100] hidden backdrop-blur-sm bg-black/40 flex items-center justify-center">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl max-w-sm w-full mx-4">
        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold text-on-surface">Edit Class Batch</h3>
            <button type="button" class="p-2 hover:bg-on-surface/5 rounded-lg transition-colors" onclick="hideEditModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form method="post" asp-page-handler="Update">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <input type="hidden" id="editClassId" name="id">
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Batch Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassName" name="batchName" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Batch Strength</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassStrength" name="strength" min="1" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Department</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassDept" name="departmentId" required>
                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Academic Year</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassYear" name="academicYearId" required>
                        @foreach (var year in Model.AcademicYears)
                        {
                            <option value="@year.Id">@year.YearLabel</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Semester</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassSem" name="semester" min="1" max="8" required>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Default Room</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editClassRoom" name="roomId">
                        <option value="">-- None --</option>
                        @foreach (var room in Model.Rooms)
                        {
                            <option value="@room.Id">@room.RoomNumber (@room.BuildingName)</option>
                        }
                    </select>
                </div>
            </div>
            
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant/10">
                <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="hideEditModal()">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Save Changes</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showEditModal(id, batchName, strength, deptId, yearId, semester, roomId) {
            document.getElementById('editClassId').value = id;
            document.getElementById('editClassName').value = batchName;
            document.getElementById('editClassStrength').value = strength;
            document.getElementById('editClassDept').value = deptId;
            document.getElementById('editClassYear').value = yearId;
            document.getElementById('editClassSem').value = semester;
            document.getElementById('editClassRoom').value = roomId || '';
            document.getElementById('editClassModal').classList.remove('hidden');
        }

        function hideEditModal() {
            document.getElementById('editClassModal').classList.add('hidden');
        }

        function showDeleteModal(id, batchName) {
            const confirmed = confirm(`Delete class batch "${batchName}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Close modal when clicking outside
        document.getElementById('editClassModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideEditModal();
            }
        });
    </script>
}
