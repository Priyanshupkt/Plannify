@page "/Admin/Teachers"
@model Plannify.Pages.Admin.Teachers.IndexModel
@{
    ViewData["Title"] = "Teachers";
    ViewData["Section"] = "Master Data";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<section class="TopBarAction">
    <button type="button" class="px-6 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow" onclick="document.getElementById('addTeacherForm').classList.toggle('hidden')">+ Add Teacher</button>
</section>

<div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-green-50 border border-green-300 text-green-800 rounded-lg flex items-center justify-between group">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-green-600">check_circle</span>
                <span>@TempData["Success"]</span>
            </div>
            <button type="button" class="p-1 hover:bg-green-100 rounded transition-colors" onclick="this.parentElement.style.display='none'">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="mb-6 px-4 py-3 bg-red-50 border border-red-300 text-red-800 rounded-lg flex items-center justify-between group">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-red-600">error</span>
                <span>@TempData["Error"]</span>
            </div>
            <button type="button" class="p-1 hover:bg-red-100 rounded transition-colors" onclick="this.parentElement.style.display='none'">
                <span class="material-symbols-outlined text-sm">close</span>
            </button>
        </div>
    }

<div id="addTeacherForm" class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border p-6 mb-6 hidden">
    <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary">person_add</span>
        <h3 class="text-lg font-semibold text-on-surface">Add New Teacher</h3>
    </div>
    <form method="post" asp-page-handler="Add">
        @Html.AntiForgeryToken()
        <div class="grid grid-cols-3 gap-4">
            <div>
                <label asp-for="NewTeacher.FullName" class="block text-sm font-medium text-on-surface mb-2">Full Name</label>
                <input type="text" asp-for="NewTeacher.FullName" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" placeholder="Dr. John Smith" required />
                <span asp-validation-for="NewTeacher.FullName" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NewTeacher.EmployeeCode" class="block text-sm font-medium text-on-surface mb-2">Employee Code</label>
                <input type="text" asp-for="NewTeacher.EmployeeCode" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" placeholder="EMP001" required />
                <span asp-validation-for="NewTeacher.EmployeeCode" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NewTeacher.Email" class="block text-sm font-medium text-on-surface mb-2">Email</label>
                <input type="email" asp-for="NewTeacher.Email" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" placeholder="teacher@college.edu" required />
                <span asp-validation-for="NewTeacher.Email" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NewTeacher.Designation" class="block text-sm font-medium text-on-surface mb-2">Designation</label>
                <input type="text" asp-for="NewTeacher.Designation" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" placeholder="Associate Professor" required />
                <span asp-validation-for="NewTeacher.Designation" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NewTeacher.DepartmentId" class="block text-sm font-medium text-on-surface mb-2">Department</label>
                <select asp-for="NewTeacher.DepartmentId" asp-items="@(new SelectList(Model.Departments, "Id", "Name"))" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" required>
                    <option value="">Select Department</option>
                </select>
                <span asp-validation-for="NewTeacher.DepartmentId" class="text-error text-xs mt-1 block"></span>
            </div>
            <div>
                <label asp-for="NewTeacher.MaxWeeklyHours" class="block text-sm font-medium text-on-surface mb-2">Max Weekly Hours</label>
                <input type="number" asp-for="NewTeacher.MaxWeeklyHours" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" value="18" min="1" required />
                <span asp-validation-for="NewTeacher.MaxWeeklyHours" class="text-error text-xs mt-1 block"></span>
            </div>
        </div>
        <div class="flex justify-end gap-3 mt-4">
            <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="document.getElementById('addTeacherForm').classList.add('hidden')">Cancel</button>
            <button type="submit" class="px-6 py-3 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Add Teacher</button>
        </div>
    </form>
</div>

<!-- Teachers Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">group</span>
        <h3 class="text-lg font-semibold text-on-surface">Teachers List</h3>
        <div class="ml-auto text-slate-500 text-sm">@Model.Teachers.Count record(s)</div>
    </div>
    
    @if (Model.Teachers.Count > 0)
    {
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">#</th>
                        <th class="px-8 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Name</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Employee Code</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Email</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Department</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Workload</th>
                        <th class="px-4 py-4 text-[10px] font-bold text-on-surface-variant uppercase tracking-widest text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in Model.Teachers)
                    {
                        var currentHours = Model.TeacherWorkloads.ContainsKey(teacher.Id) ? Model.TeacherWorkloads[teacher.Id] : 0;
                        var percentage = (currentHours / teacher.MaxWeeklyHours) * 100;
                        var workloadColor = percentage >= 100 ? "bg-error text-on-error" : percentage >= 80 ? "bg-warning text-on-warning" : "bg-success text-on-success";
                        var deptName = Model.Departments.FirstOrDefault(d => d.Id == teacher.DepartmentId)?.Name ?? "N/A";

                        <tr class="hover:bg-surface-container-low/30 transition-colors group border-t border-outline-variant/10">
                            <td class="px-8 py-5 text-sm text-on-surface">@(Model.Teachers.IndexOf(teacher) + 1)</td>
                            <td class="px-8 py-5 text-sm font-medium text-on-surface">@teacher.FullName</td>
                            <td class="px-4 py-5 text-xs"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed font-bold rounded-full">@teacher.EmployeeCode</span></td>
                            <td class="px-4 py-5 text-sm text-on-surface-variant">@teacher.Email</td>
                            <td class="px-4 py-5 text-sm text-on-surface">@deptName</td>
                            <td class="px-4 py-5 text-xs"><span class="px-3 py-1 @workloadColor font-bold rounded-full">@currentHours.ToString("F1")/@teacher.MaxWeeklyHours hrs</span></td>
                            <td class="px-4 py-5">
                                <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <a href="/Admin/Teachers/Profile?id=@teacher.Id" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" title="View Profile">
                                        <span class="material-symbols-outlined text-lg">person</span>
                                    </a>
                                    <button type="button" class="p-2 rounded-lg hover:bg-primary/10 text-primary transition-colors" 
                                            onclick="showEditTeacherModal(@teacher.Id, '@teacher.FullName', '@teacher.EmployeeCode', '@teacher.Email', '@teacher.Designation', @teacher.DepartmentId, @teacher.MaxWeeklyHours)" title="Edit Teacher">
                                        <span class="material-symbols-outlined text-lg">edit</span>
                                    </button>
                                    <button type="button" class="p-2 rounded-lg hover:bg-error/10 text-error transition-colors" 
                                            onclick="showDeleteModal('@teacher.Id', '@teacher.FullName')">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-12 px-8">
            <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-3">inbox</span>
            <p class="text-on-surface-variant text-center">No teachers found. Create one to get started.</p>
        </div>
    }
</div>

<!-- Edit Teacher Modal -->
<div id="editTeacherModal" class="fixed inset-0 z-[100] hidden backdrop-blur-sm bg-black/40 flex items-center justify-center">
    <div class="bg-surface-container-lowest rounded-2xl shadow-2xl max-w-sm w-full mx-4">
        <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold text-on-surface">Edit Teacher</h3>
            <button type="button" class="p-2 hover:bg-on-surface/5 rounded-lg transition-colors" onclick="hideEditTeacherModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form method="post" asp-page-handler="Update">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 space-y-4">
                <input type="hidden" id="editTeacherId" name="id" />
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Full Name</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editFullName" name="fullName" required />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Employee Code</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editEmployeeCode" name="employeeCode" required />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Email</label>
                    <input type="email" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editEmail" name="email" required />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Designation</label>
                    <input type="text" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editDesignation" name="designation" required />
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Department</label>
                    <select class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editDepartmentId" name="departmentId" required>
                        @foreach (var dept in Model.Departments)
                        {
                            <option value="@dept.Id">@dept.Name</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label class="block text-sm font-medium text-on-surface mb-2">Max Weekly Hours</label>
                    <input type="number" class="w-full px-4 py-3 bg-surface-container-low border-0 rounded-xl text-sm focus:ring-2 focus:ring-primary/30 outline-none" id="editMaxWeeklyHours" name="maxWeeklyHours" min="1" required />
                </div>
            </div>
            
            <div class="flex items-center justify-end gap-3 px-6 py-4 border-t border-outline-variant/10">
                <button type="button" class="px-4 py-2 text-on-surface-variant hover:bg-on-surface/5 rounded-xl transition-colors" onclick="hideEditTeacherModal()">Cancel</button>
                <button type="submit" class="px-4 py-2 bg-primary text-on-primary font-medium rounded-xl hover:shadow-md transition-shadow">Update</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function showEditTeacherModal(id, fullName, employeeCode, email, designation, departmentId, maxWeeklyHours) {
            document.getElementById('editTeacherId').value = id;
            document.getElementById('editFullName').value = fullName;
            document.getElementById('editEmployeeCode').value = employeeCode;
            document.getElementById('editEmail').value = email;
            document.getElementById('editDesignation').value = designation;
            document.getElementById('editDepartmentId').value = departmentId;
            document.getElementById('editMaxWeeklyHours').value = maxWeeklyHours;
            document.getElementById('editTeacherModal').classList.remove('hidden');
        }

        function hideEditTeacherModal() {
            document.getElementById('editTeacherModal').classList.add('hidden');
        }

        function showDeleteModal(id, name) {
            const confirmed = confirm(`Delete teacher "${name}"? This cannot be undone.`);
            if (confirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = location.pathname + '?handler=Delete';
                
                let tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);
                
                let idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);
                
                document.body.appendChild(form);
                form.submit();
            }
        }

        // Close modal when clicking outside
        document.getElementById('editTeacherModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                hideEditTeacherModal();
            }
        });
    </script>
}
