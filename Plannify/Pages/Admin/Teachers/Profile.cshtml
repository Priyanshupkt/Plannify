@page "{id:int}"
@model Plannify.Pages.Admin.Teachers.ProfileModel
@{
    ViewData["Title"] = $"Profile - {Model.Teacher?.FullName}";
    ViewData["Section"] = "Teachers";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<!-- Header -->
<div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-on-surface flex items-center gap-2">
        <span class="material-symbols-outlined text-3xl">person</span>
        @Model.Teacher?.FullName
    </h2>
    <a href="/Admin/Teachers/" class="px-4 py-2 text-primary hover:bg-primary/10 rounded-lg transition-colors flex items-center gap-2">
        <span class="material-symbols-outlined">arrow_back</span>
        Back
    </a>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="mb-6 px-4 py-3 bg-green-50 border border-green-300 text-green-800 rounded-lg flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-green-600">check_circle</span>
            <span>@TempData["Success"]</span>
        </div>
        <button type="button" class="p-1 hover:bg-green-100 rounded transition-colors" onclick="this.parentElement.style.display='none'">
            <span class="material-symbols-outlined text-sm">close</span>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="mb-6 px-4 py-3 bg-red-50 border border-red-300 text-red-800 rounded-lg flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-red-600">error</span>
            <span>@TempData["Error"]</span>
        </div>
        <button type="button" class="p-1 hover:bg-red-100 rounded transition-colors" onclick="this.parentElement.style.display='none'">
            <span class="material-symbols-outlined text-sm">close</span>
        </button>
    </div>
}

@if (Model.Teacher == null)
{
    <div class="px-4 py-3 bg-yellow-50 border border-yellow-300 text-yellow-800 rounded-lg flex items-center gap-3">
        <span class="material-symbols-outlined text-yellow-600">warning</span>
        <span>Teacher not found.</span>
    </div>
    return;
}

<!-- Personal Information & Workload Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Personal Information -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
        <div class="px-6 py-4 bg-primary text-on-primary border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold">Personal Information</h3>
        </div>
        <div class="px-6 py-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Full Name</p>
                    <p class="text-sm font-medium text-on-surface">@Model.Teacher.FullName</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Employee Code</p>
                    <span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed text-xs font-bold rounded-full inline-block">@Model.Teacher.EmployeeCode</span>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Email</p>
                    <a href="mailto:@Model.Teacher.Email" class="text-sm text-primary hover:underline">@Model.Teacher.Email</a>
                </div>
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Department</p>
                    <p class="text-sm font-medium text-on-surface">@Model.Teacher.Department?.Name</p>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Designation</p>
                    <p class="text-sm font-medium text-on-surface">@Model.Teacher.Designation</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Max Weekly Hours</p>
                    <span class="px-3 py-1 bg-warning-fixed text-on-warning-fixed text-xs font-bold rounded-full inline-block">@Model.Teacher.MaxWeeklyHours hrs</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Workload Analysis -->
    <div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
        <div class="px-6 py-4 bg-success text-on-success border-b border-outline-variant/10">
            <h3 class="text-lg font-semibold">Workload Analysis</h3>
        </div>
        <div class="px-6 py-6 space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Current Hours</p>
                    <p class="text-sm font-medium text-on-surface">@Model.CurrentHours.ToString("F1") hrs</p>
                </div>
                <div>
                    <p class="text-xs font-bold text-on-surface-variant uppercase mb-1">Workload %</p>
                    <p>
                        @{
                            var percentage = (Model.CurrentHours / Model.Teacher.MaxWeeklyHours) * 100;
                            var workloadColor = percentage >= 100 ? "bg-error text-on-error" : percentage >= 80 ? "bg-warning text-on-warning" : "bg-success text-on-success";
                        }
                        <span class="px-3 py-1 @workloadColor text-xs font-bold rounded-full inline-block">@percentage.ToString("F0")%</span>
                    </p>
                </div>
            </div>
            <div>
                <p class="text-xs font-bold text-on-surface-variant uppercase mb-2">Active Semester</p>
                <p class="text-sm font-medium text-on-surface">@(Model.ActiveSemester?.Name ?? "No active semester")</p>
            </div>
            <div>
                <p class="text-xs font-bold text-on-surface-variant uppercase mb-2">Workload Progress</p>
                @{
                    var progress = Math.Min(percentage, 100);
                    var progressColorClass = percentage >= 100 ? "bg-error" : percentage >= 80 ? "bg-warning" : "bg-success";
                }
                <div class="w-full bg-surface-container-low rounded-full h-2">
                    <div class="@progressColorClass h-2 rounded-full transition-all" style="width: @progress%"></div>
                </div>
                <p class="text-xs text-on-surface-variant mt-2">@progress.ToString("F0")% of @Model.Teacher.MaxWeeklyHours hours</p>
            </div>
        </div>
    </div>
</div>

<!-- Assigned Subjects Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden mb-6">
    <div class="flex items-center gap-3 px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <span class="material-symbols-outlined text-primary">library_books</span>
        <h3 class="text-lg font-semibold text-on-surface">Assigned Subjects in Active Semester</h3>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Subject Code</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Subject Name</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Credits</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Classes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AssignedSubjects.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-on-surface-variant">
                            No subjects assigned in active semester.
                        </td>
                    </tr>
                }
                @foreach (var subject in Model.AssignedSubjects)
                {
                    <tr class="border-t border-outline-variant/10 hover:bg-surface-container-low/30">
                        <td class="px-6 py-4"><span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed text-xs font-bold rounded-full">@subject.Code</span></td>
                        <td class="px-6 py-4 font-medium text-on-surface">@subject.Name</td>
                        <td class="px-6 py-4">
                            @{
                                var typeBg = subject.SubjectType switch
                                {
                                    "Theory" => "bg-primary-fixed text-on-primary-fixed",
                                    "Lab" => "bg-error text-on-error",
                                    "Elective" => "bg-warning-fixed text-on-warning-fixed",
                                    _ => "bg-surface-container-low text-on-surface"
                                };
                            }
                            <span class="px-3 py-1 @typeBg text-xs font-bold rounded-full inline-block">@subject.SubjectType</span>
                        </td>
                        <td class="px-6 py-4"><span class="px-3 py-1 bg-success-fixed text-on-success-fixed text-xs font-bold rounded-full">@subject.Credits</span></td>
                        <td class="px-6 py-4 text-on-surface">@(Model.SubjectClassCount.ContainsKey(subject.Id) ? Model.SubjectClassCount[subject.Id] : 0)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Timetable Slots Table -->
<div class="bg-surface-container-lowest rounded-2xl shadow-sm ghost-border overflow-hidden">
    <div class="flex items-center justify-between px-8 py-4 bg-surface-container-low/50 border-b border-outline-variant/10">
        <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary">schedule</span>
            <h3 class="text-lg font-semibold text-on-surface">Timetable Slots</h3>
        </div>
        <button type="button" class="px-4 py-2 text-sm font-medium text-primary hover:bg-primary/10 rounded-lg transition-colors" 
                onclick="document.getElementById('slotTable').classList.toggle('hidden')">
            <span class="material-symbols-outlined inline text-lg align-middle">visibility</span> Toggle Details
        </button>
    </div>
    <div class="overflow-x-auto" id="slotTable">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-surface-container-low/50 border-b border-outline-variant/10">
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Day</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Time</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Subject</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Class</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Room</th>
                    <th class="px-6 py-3 text-left text-xs font-bold text-on-surface-variant uppercase">Type</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.TimetableSlots.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-on-surface-variant">
                            No timetable slots assigned.
                        </td>
                    </tr>
                }
                @foreach (var slot in Model.TimetableSlots.OrderBy(s => s.Day))
                {
                    <tr class="border-t border-outline-variant/10 hover:bg-surface-container-low/30">
                        <td class="px-6 py-4 font-semibold text-on-surface">@slot.Day</td>
                        <td class="px-6 py-4 text-on-surface">@slot.StartTime.ToString(@"hh\:mm") - @slot.EndTime.ToString(@"hh\:mm")</td>
                        <td class="px-6 py-4 text-on-surface">@(slot.Subject?.Name ?? "N/A")</td>
                        <td class="px-6 py-4 text-on-surface">@(slot.ClassBatch?.BatchName ?? "N/A")</td>
                        <td class="px-6 py-4 text-on-surface">@(slot.Room?.RoomNumber ?? "N/A")</td>
                        <td class="px-6 py-4">
                            @{
                                var slotTypeBg = slot.SlotType switch
                                {
                                    "Theory" => "bg-primary-fixed text-on-primary-fixed",
                                    "Lab" => "bg-error text-on-error",
                                    "Elective" => "bg-warning-fixed text-on-warning-fixed",
                                    "GAP" => "bg-surface-container-low text-on-surface",
                                    _ => "bg-on-surface-variant/20 text-on-surface"
                                };
                            }
                            <span class="px-3 py-1 @slotTypeBg text-xs font-bold rounded-full inline-block">@slot.SlotType</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
