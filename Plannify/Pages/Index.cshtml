@page
@{
    ViewData["Title"] = "Faculty TimeGrid Pro - Home";
}

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 20px;
        border-radius: 10px;
        margin-bottom: 50px;
        text-align: center;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }
    
    .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 15px;
    }
    
    .hero-section p {
        font-size: 1.1rem;
        margin-bottom: 0;
        opacity: 0.95;
    }
    
    .feature-card {
        background: white;
        border: none;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
        transition: all 0.3s ease;
        height: 100%;
        padding: 30px;
    }
    
    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(102, 126, 234, 0.2);
    }
    
    .feature-icon {
        font-size: 3rem;
        margin-bottom: 15px;
        width: 80px;
        height: 80px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: auto;
        margin-right: auto;
    }
    
    .admin-icon {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    
    .teacher-icon {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }
    
    .feature-card h5 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #333;
        margin: 15px 0;
    }
    
    .feature-card p {
        color: #666;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 20px;
    }
    
    .btn-feature {
        padding: 12px 30px;
        border-radius: 6px;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        display: inline-block;
    }
    
    .btn-admin {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }
    
    .btn-admin:hover {
        background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
        color: white;
        transform: scale(1.02);
    }
    
    .btn-teacher {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }
    
    .btn-teacher:hover {
        background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
        color: white;
        transform: scale(1.02);
    }
    
    .features-grid {
        margin-top: 40px;
    }
    
    .feature-list {
        list-style: none;
        padding: 0;
        margin: 15px 0;
        text-align: left;
    }
    
    .feature-list li {
        padding: 8px 0;
        color: #555;
        font-size: 0.9rem;
    }
    
    .feature-list li:before {
        content: "✓ ";
        color: #667eea;
        font-weight: bold;
        margin-right: 10px;
    }
</style>

<!-- Hero Section -->
<div class="hero-section">
    <h1><i class="fas fa-calendar-alt me-2"></i>Faculty TimeGrid Pro</h1>
    <p>Efficient Timetable Management & Scheduling System</p>
</div>

<!-- Features Section -->
<div class="row features-grid">
    <div class="col-md-6 mb-4">
        <div class="feature-card">
            <div class="feature-icon admin-icon">
                <i class="fas fa-cogs"></i>
            </div>
            <h5>Admin Panel</h5>
            <p>Manage teachers, subjects, classes, rooms, and timetable configurations with ease.</p>
            <ul class="feature-list">
                <li>Configure departments and roles</li>
                <li>Manage academic structures</li>
                <li>Create and assign timetables</li>
                <li>Monitor substitutions</li>
                <li>Generate reports and exports</li>
            </ul>
            <a href="/Admin/Teachers" class="btn btn-feature btn-admin mt-3">
                <i class="fas fa-arrow-right me-2"></i>Go to Admin Panel
            </a>
        </div>
    </div>
    
    <div class="col-md-6 mb-4">
        <div class="feature-card">
            <div class="feature-icon teacher-icon">
                <i class="fas fa-chalkboard-user"></i>
            </div>
            <h5>Teacher Dashboard</h5>
            <p>View your assigned timetable, workload, and manage substitutions.</p>
            <ul class="feature-list">
                <li>View your schedule</li>
                <li>Check workload distribution</li>
                <li>Manage substitutions</li>
                <li>Access class information</li>
                <li>Export schedule details</li>
            </ul>
            <a href="/Teacher/Dashboard" class="btn btn-feature btn-teacher mt-3">
                <i class="fas fa-arrow-right me-2"></i>Go to Teacher Dashboard
            </a>
        </div>
    </div>
</div>

<!-- Additional Info Section -->
<div class="row mt-5" style="opacity: 0.8;">
    <div class="col-12 text-center">
        <hr>
        <p style="color: #666; font-size: 0.9rem;">
            <i class="fas fa-info-circle me-2"></i>Log in with your credentials to access the full features of Faculty TimeGrid Pro
        </p>
    </div>
</div>
