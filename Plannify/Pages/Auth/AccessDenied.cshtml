@page "/Auth/AccessDenied"
@model Plannify.Pages.Auth.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .error-container {
            max-width: 500px;
            width: 100%;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            padding: 3rem 2rem;
            text-align: center;
        }
        .error-icon {
            font-size: 4rem;
            margin-bottom: 1rem;
        }
        .error-code {
            font-size: 3rem;
            font-weight: 700;
            color: #e74c3c;
            margin: 0;
        }
        .error-message {
            font-size: 1.2rem;
            color: #333;
            margin: 1rem 0 2rem 0;
        }
        .btn-dashboard {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            color: white;
            padding: 0.75rem 2rem;
            border-radius: 6px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-dashboard:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
            color: white;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-icon">🔐</div>
        <p class="error-code">403</p>
        <h1 style="color: #333; font-size: 1.8rem; margin-bottom: 1rem;">Access Denied</h1>
        <p class="error-message">You do not have permission to access this page. Contact your administrator if you believe this is an error.</p>
        <a href="@(User.Identity?.IsAuthenticated == true ? "/Admin/Dashboard" : "/Auth/Login")" class="btn-dashboard">
            @(User.Identity?.IsAuthenticated == true ? "Back to Dashboard" : "Return to Login")
        </a>
    </div>
</body>
</html>
